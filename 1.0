import React, { useState, useRef, useEffect, useCallback, useMemo, useLayoutEffect } from 'react';
import { motion, AnimatePresence } from 'framer-motion';

// --- 1. 公用程式函式 (Utilities) ---
// 存放不依賴 React 狀態的純函式，負責具體的資料處理任務。

const toBase64 = file => new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.readAsDataURL(file);
    reader.onload = () => resolve(reader.result);
    reader.onerror = error => reject(error);
});

const processDataUrl = (dataUrl) => {
    if (!dataUrl) return { mimeType: null, data: null };
    const parts = dataUrl.split(',');
    if (parts.length !== 2) return { mimeType: null, data: null };
    const mimeType = parts[0].match(/:(.*?);/)?.[1];
    if (!mimeType) return { mimeType: null, data: null };
    return { mimeType, data: parts[1] };
};

const WORD_FREQ_KEY = 'promptWordFrequencies';
const getWordFrequencies = () => {
    try {
        const storedFrequencies = localStorage.getItem(WORD_FREQ_KEY);
        return storedFrequencies ? JSON.parse(storedFrequencies) : { positive: {}, negative: {} };
    } catch (error) {
        console.error("無法從 localStorage 解析詞頻:", error);
        return { positive: {}, negative: {} };
    }
};

const updateWordFrequencies = (text, type) => {
    if (!text || typeof text !== 'string') return;
    const frequencies = getWordFrequencies();
    const words = text.toLowerCase().split(/[\s,，]+/).filter(word => word.length >= 3);
    words.forEach(word => {
        const cleanWord = word.trim();
        if (cleanWord) {
            frequencies[type][cleanWord] = (frequencies[type][cleanWord] || 0) + 1;
        }
    });
    try {
        localStorage.setItem(WORD_FREQ_KEY, JSON.stringify(frequencies));
    } catch (error) {
        console.error("無法儲存詞頻到 localStorage:", error);
    }
};

const getSuggestions = (type) => {
    const frequencies = getWordFrequencies();
    const wordMap = frequencies[type] || {};
    return Object.entries(wordMap)
        .sort(([, countA], [, countB]) => countB - countA)
        .slice(0, 10)
        .map(([word]) => word);
};

// --- 2. API 呼叫 (API Calls) ---
// 封裝所有與後端 API 的互動，例如圖片生成、文字生成等。

const generateTextWithRetry = async (payload, maxRetries = 3) => {
    const apiKey = "";
    const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-05-20:generateContent?key=${apiKey}`;
    for (let i = 0; i < maxRetries; i++) {
        try {
            const response = await fetch(apiUrl, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
            if (!response.ok) throw new Error(`API 文字請求失敗，狀態碼 ${response.status}：${await response.text() || response.statusText}`);
            const result = await response.json();
            const text = result?.candidates?.[0]?.content?.parts?.[0]?.text;
            if (text) return text;
            throw new Error("API 回應未包含文字資料。");
        } catch (error) {
            console.error(`第 ${i + 1}/${maxRetries} 次文字生成嘗試失敗:`, error);
            if (i === maxRetries - 1) throw error;
            await new Promise(res => setTimeout(res, 1000 * Math.pow(2, i)));
        }
    }
};

const generateImageWithRetry = async (payload, maxRetries = 3) => {
    const apiKey = ""; 
    const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-image-preview:generateContent?key=${apiKey}`;
    for (let i = 0; i < maxRetries; i++) {
        try {
            const response = await fetch(apiUrl, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
            if (!response.ok) throw new Error(`API 請求失敗，狀態碼 ${response.status}：${await response.text() || response.statusText}`);
            const result = await response.json();
            const base64Data = result?.candidates?.[0]?.content?.parts?.find(p => p.inlineData)?.inlineData?.data;
            if (!base64Data) throw new Error("API 回應未包含圖片資料。");
            return `data:image/png;base64,${base64Data}`;
        } catch (error) {
            console.error(`第 ${i + 1}/${maxRetries} 次嘗試失敗:`, error);
            if (i === maxRetries - 1) throw error;
            await new Promise(res => setTimeout(res, 2000 * Math.pow(2, i)));
        }
    }
};

const detectImageProperties = async (imageDataUrl) => {
    try {
        const { mimeType, data } = processDataUrl(imageDataUrl);
        if (!mimeType || !data) return { type: 'unknown', gender: 'unknown', personCount: 0 };
        const prompt = "Analyze this image. Determine if it is a 'photograph' or an 'illustration'. Determine the gender of the primary subject ('male', 'female', 'unknown'). Count the number of people visible in the image. Respond with a JSON object containing 'type', 'gender', and 'personCount' keys. Example: {\"type\": \"photograph\", \"gender\": \"female\", \"personCount\": 1}";
        const payload = {
            contents: [{ parts: [{ text: prompt }, { inlineData: { mimeType, data } }] }],
            generationConfig: {
                responseMimeType: "application/json",
                responseSchema: {
                    type: "OBJECT",
                    properties: {
                        "type": { "type": "STRING" },
                        "gender": { "type": "STRING" },
                        "personCount": { "type": "INTEGER" },
                    },
                    required: ["type", "gender", "personCount"]
                }
            }
        };
        const responseText = await generateTextWithRetry(payload);
        const properties = JSON.parse(responseText);

        const type = properties.type?.toLowerCase().includes('photograph') ? 'photograph' : 'illustration';
        let gender = 'unknown';
        if (properties.gender?.toLowerCase().includes('female')) {
            gender = 'female';
        } else if (properties.gender?.toLowerCase().includes('male')) {
            gender = 'male';
        }
        const personCount = properties.personCount || 0;
        
        return { type, gender, personCount };
    } catch (error) {
        console.error("圖片屬性偵測失敗:", error);
        return { type: 'unknown', gender: 'unknown', personCount: 0 };
    }
};

const generativeFill = async (imageDataUrl) => {
    try {
        const { mimeType, data } = processDataUrl(imageDataUrl);
        if (!mimeType || !data) throw new Error("無效的圖片格式。");
        const prompt = "ULTIMATE PRIORITY TASK: Seamless Outpainting. This image contains a central subject on a transparent background. Your one and only job is to fill the transparent areas by intelligently extending the existing image. You must analyze the subject, colors, textures, and background patterns and continue them into the transparent regions. The final result MUST be a complete, realistic, square image with ZERO transparency. FORBIDDEN elements: You are strictly forbidden from creating any solid color bars (especially black or white), borders, or frames. The transition between the original image and the filled areas must be completely invisible.";
        const payload = {
            contents: [{ parts: [{ text: prompt }, { inlineData: { mimeType, data } }] }],
            generationConfig: { responseModalities: ['TEXT', 'IMAGE'] }
        };
        return await generateImageWithRetry(payload);
    } catch (error) {
        console.error("生成式填充 API 呼叫失敗:", error);
        throw new Error("生成式填充 API 呼叫失敗：" + error.message);
    }
};

const removeBackgroundAI = async (imageDataUrl) => {
    try {
        const { mimeType, data } = processDataUrl(imageDataUrl);
        if (!mimeType || !data) throw new Error("無效的圖片格式。");
        const prompt = "CRITICAL TASK: Background Removal. Your only task is to accurately identify the main subject(s) in this image and completely remove the background, leaving only the subject(s) on a fully transparent background. Do not alter the subject(s) in any way. The output must be a PNG with a transparent alpha channel.";
        const payload = {
            contents: [{ parts: [{ text: prompt }, { inlineData: { mimeType, data } }] }],
            generationConfig: { responseModalities: ['TEXT', 'IMAGE'] }
        };
        return await generateImageWithRetry(payload);
    } catch (error) {
        console.error("AI 去背 API 呼叫失敗:", error);
        throw new Error("AI 去背 API 呼叫失敗：" + error.message);
    }
};

const addChromaKeyBackgroundAI = async (imageDataUrl, keyColor = 'green') => {
    try {
        const { mimeType, data } = processDataUrl(imageDataUrl);
        if (!mimeType || !data) throw new Error("無效的圖片格式。");
        
        const colors = { 
            green: { rgb: '(0, 255, 0)', name: 'green screen green' }, 
            red: { rgb: '(255, 0, 0)', name: 'pure red' }, 
            blue: { rgb: '(0, 0, 255)', name: 'pure blue' }, 
            black: { rgb: '(0, 0, 0)', name: 'pure black' }, 
        };
        const selectedColor = colors[keyColor] || colors.green;

        const prompt = `CRITICAL TASK: Isolate Subject on Chroma Key Background. Your only task is to accurately identify the main subject(s) in this image and place them on a solid, pure, flat ${selectedColor.name} background with the exact RGB value of ${selectedColor.rgb}. The subject(s) must be cleanly separated with no shadows or color spill. Do not alter the subject(s) in any way. The output must be a standard image file (e.g., PNG or JPEG) with the subject on the chroma key background.`;
        
        const payload = {
            contents: [{ parts: [{ text: prompt }, { inlineData: { mimeType, data } }] }],
            generationConfig: { responseModalities: ['TEXT', 'IMAGE'] }
        };
        return await generateImageWithRetry(payload);
    } catch (error) {
        console.error(`AI 添加${keyColor}背景 API 呼叫失敗:`, error);
        throw new Error(`AI 添加${keyColor}背景 API 呼叫失敗：` + error.message);
    }
};

// --- 3. 圖片處理 (Image Processing) ---
// 包含所有在前端對圖片進行操作的函式，如裁切、去背、加字等。

const resizeImage = (imageUrl, width, height) => {
    return new Promise((resolve, reject) => {
        const img = new Image();
        img.crossOrigin = 'Anonymous';
        img.onload = () => {
            const canvas = document.createElement('canvas');
            canvas.width = width; canvas.height = height;
            const ctx = canvas.getContext('2d');
            ctx.imageSmoothingEnabled = true; ctx.imageSmoothingQuality = 'high';
            ctx.drawImage(img, 0, 0, width, height);
            resolve(canvas.toDataURL('image/png'));
        };
        img.onerror = (err) => reject(new Error("無法縮放圖片。"));
        img.src = imageUrl;
    });
};

const splitImage = (imageSrc) => {
    return new Promise((resolve, reject) => {
        const img = new Image();
        img.crossOrigin = "Anonymous";
        img.onload = () => {
            const width = img.width; const height = img.height;
            const canvas = document.createElement('canvas');
            canvas.width = width; canvas.height = height;
            const ctx = canvas.getContext('2d', { willReadFrequently: true });
            ctx.drawImage(img, 0, 0);
            const imageData = ctx.getImageData(0, 0, width, height);
            const data = imageData.data;
            const verticalProjection = new Array(width).fill(0);
            for (let x = 0; x < width; x++) {
                for (let y = 0; y < height; y++) {
                    verticalProjection[x] += data[(y * width + x) * 4 + 3];
                }
            }
            const searchStart = Math.floor(width * 0.4);
            const searchEnd = Math.floor(width * 0.6);
            let minAlphaSum = Infinity;
            let splitX = Math.floor(width / 2);
            for (let x = searchStart; x < searchEnd; x++) {
                if (verticalProjection[x] < minAlphaSum) {
                    minAlphaSum = verticalProjection[x];
                    splitX = x;
                }
            }
            if (minAlphaSum === 0) {
                 let firstOpaqueX = -1; let lastOpaqueX = -1;
                 for(let x = 0; x < width; x++) {
                     if (verticalProjection[x] > 0) {
                         if (firstOpaqueX === -1) firstOpaqueX = x;
                         lastOpaqueX = x;
                     }
                 }
                 if(firstOpaqueX !== -1 && lastOpaqueX !== -1) {
                     const centerX = firstOpaqueX + (lastOpaqueX - firstOpaqueX) / 2;
                     const newSearchStart = Math.max(0, Math.floor(centerX - width * 0.1));
                     const newSearchEnd = Math.min(width, Math.floor(centerX + width * 0.1));
                     minAlphaSum = Infinity;
                     for (let x = newSearchStart; x < newSearchEnd; x++) {
                        if (verticalProjection[x] < minAlphaSum) {
                            minAlphaSum = verticalProjection[x];
                            splitX = x;
                        }
                    }
                 }
            }
            const canvasLeft = document.createElement('canvas');
            canvasLeft.width = splitX; canvasLeft.height = height;
            const ctxLeft = canvasLeft.getContext('2d');
            ctxLeft.drawImage(img, 0, 0, splitX, height, 0, 0, splitX, height);
            const canvasRight = document.createElement('canvas');
            canvasRight.width = width - splitX; canvasRight.height = height;
            const ctxRight = canvasRight.getContext('2d');
            ctxRight.drawImage(img, splitX, 0, width - splitX, height, 0, 0, width - splitX, height);
            resolve({ leftHalf: canvasLeft.toDataURL('image/png'), rightHalf: canvasRight.toDataURL('image/png') });
        };
        img.onerror = (err) => reject(new Error("圖片載入失敗，無法進行裁切。"));
        img.src = imageSrc;
    });
};

const cropToSubjectEdge = (imageSrc, side) => {
    return new Promise((resolve, reject) => {
        const img = new Image();
        img.crossOrigin = "Anonymous";
        img.onload = () => {
            const tempCanvas = document.createElement('canvas');
            const halfWidth = img.width; const height = img.height;
            tempCanvas.width = halfWidth; tempCanvas.height = height;
            const tempCtx = tempCanvas.getContext('2d');
            tempCtx.drawImage(img, 0, 0);
            const imageData = tempCtx.getImageData(0, 0, halfWidth, height);
            const data = imageData.data;
            let subjectEdgeX = 0; let subjectFound = false;
            if (side === 'left') { 
                for (let x = halfWidth - 1; x >= 0; x--) {
                    for (let y = 0; y < height; y++) {
                        if (data[(y * halfWidth + x) * 4 + 3] > 10) {
                            subjectEdgeX = x; subjectFound = true; break;
                        }
                    }
                    if (subjectFound) break;
                }
            } else {
                for (let x = 0; x < halfWidth; x++) {
                    for (let y = 0; y < height; y++) {
                        if (data[(y * halfWidth + x) * 4 + 3] > 10) {
                            subjectEdgeX = x; subjectFound = true; break;
                        }
                    }
                    if (subjectFound) break;
                }
            }
            if (!subjectFound) { resolve(imageSrc); return; }
            const finalCanvas = document.createElement('canvas');
            finalCanvas.width = height; finalCanvas.height = height;
            const finalCtx = finalCanvas.getContext('2d');
            let drawX = (side === 'left') ? (finalCanvas.width - 1) - subjectEdgeX : -subjectEdgeX;
            finalCtx.drawImage(img, drawX, 0);
            resolve(finalCanvas.toDataURL('image/png'));
        };
        img.onerror = (err) => reject(new Error("圖片載入失敗，無法進行邊緣對齊。"));
        img.src = imageSrc;
    });
};

const refineAlphaMask = (imageSrc, iterations = 2) => {
    return new Promise((resolve, reject) => {
        const img = new Image();
        img.crossOrigin = "Anonymous";
        img.onload = () => {
            const canvas = document.createElement('canvas');
            const w = img.width; const h = img.height;
            canvas.width = w; canvas.height = h;
            const ctx = canvas.getContext('2d', { willReadFrequently: true });
            ctx.drawImage(img, 0, 0);
            const imageData = ctx.getImageData(0, 0, w, h);
            const data = imageData.data;
            let mask = new Uint8Array(w * h);
            for (let i = 0; i < data.length; i += 4) mask[i / 4] = data[i + 3] > 128 ? 255 : 0;
            let processedMask = mask;
            for (let iter = 0; iter < iterations; iter++) {
                const nextMask = new Uint8Array(processedMask.length);
                for (let y = 1; y < h - 1; y++) {
                    for (let x = 1; x < w - 1; x++) {
                        const idx = y * w + x; let maxVal = 0;
                        for (let dy = -1; dy <= 1; dy++) for (let dx = -1; dx <= 1; dx++) maxVal = Math.max(maxVal, processedMask[(y + dy) * w + (x + dx)]);
                        nextMask[idx] = maxVal;
                    }
                }
                processedMask = nextMask;
            }
            for (let iter = 0; iter < iterations; iter++) {
                const nextMask = new Uint8Array(processedMask.length);
                for (let y = 1; y < h - 1; y++) {
                    for (let x = 1; x < w - 1; x++) {
                        const idx = y * w + x; let minVal = 255;
                        for (let dy = -1; dy <= 1; dy++) for (let dx = -1; dx <= 1; dx++) minVal = Math.min(minVal, processedMask[(y + dy) * w + (x + dx)]);
                        nextMask[idx] = minVal;
                    }
                }
                processedMask = nextMask;
            }
            for (let i = 0; i < data.length; i += 4) data[i + 3] = processedMask[i / 4];
            ctx.putImageData(imageData, 0, 0);
            resolve(canvas.toDataURL('image/png'));
        };
        img.onerror = (err) => reject(new Error("圖片載入失敗，無法修復透明度。"));
        img.src = imageSrc;
    });
};

const removeChromaKeyBackground = (imageSrc, keyColor = 'green', tolerance = 40, edgeOffset = 0, featherAmount = 0) => {
    return new Promise((resolve, reject) => {
        const img = new Image();
        img.crossOrigin = "Anonymous";
        img.onload = () => {
            const canvas = document.createElement('canvas');
            const w = img.width; const h = img.height;
            canvas.width = w; canvas.height = h;
            const ctx = canvas.getContext('2d', { willReadFrequently: true });
            ctx.drawImage(img, 0, 0);
            const imageData = ctx.getImageData(0, 0, w, h);
            const data = imageData.data;
            const keyColors = { green: [0, 255, 0], red: [255, 0, 0], blue: [0, 0, 255], black: [0, 0, 0] };
            const [kr, kg, kb] = keyColors[keyColor] || keyColors.green;
            const mask = new Uint8Array(w * h);
            for (let i = 0; i < data.length; i += 4) {
                const r = data[i], g = data[i + 1], b = data[i + 2];
                const distance = Math.sqrt(Math.pow(r - kr, 2) + Math.pow(g - kg, 2) + Math.pow(b - kb, 2));
                mask[i / 4] = (distance < tolerance * 2.55) ? 0 : 255;
            }
            let processedMask = mask;
            if (edgeOffset !== 0) {
                const iterations = Math.abs(Math.round(edgeOffset)); let currentMask = processedMask;
                for (let i = 0; i < iterations; i++) {
                    const nextMask = new Uint8Array(currentMask.length);
                    for (let y = 1; y < h - 1; y++) for (let x = 1; x < w - 1; x++) {
                        const idx = y * w + x;
                        if (edgeOffset > 0) { let maxVal = 0; for (let dy = -1; dy <= 1; dy++) for (let dx = -1; dx <= 1; dx++) maxVal = Math.max(maxVal, currentMask[(y + dy) * w + (x + dx)]); nextMask[idx] = maxVal; } 
                        else { let minVal = 255; for (let dy = -1; dy <= 1; dy++) for (let dx = -1; dx <= 1; dx++) minVal = Math.min(minVal, currentMask[(y + dy) * w + (x + dx)]); nextMask[idx] = minVal; }
                    }
                    currentMask = nextMask;
                }
                processedMask = currentMask;
            }
            if (featherAmount > 0) {
                const radius = Math.round(featherAmount);
                if (radius > 0) {
                    const tempMask = new Uint8Array(processedMask.length);
                    const diameter = radius * 2 + 1;
                    for (let y = 0; y < h; y++) {
                        let sum = 0;
                        for (let i = -radius; i <= radius; i++) sum += processedMask[y * w + Math.max(0, Math.min(w - 1, i))];
                        for (let x = 0; x < w; x++) {
                            tempMask[y * w + x] = sum / diameter;
                            sum += processedMask[y * w + Math.min(w - 1, x + radius + 1)] - processedMask[y * w + Math.max(0, x - radius)];
                        }
                    }
                    for (let x = 0; x < w; x++) {
                        let sum = 0;
                        for (let i = -radius; i <= radius; i++) sum += tempMask[Math.max(0, Math.min(h - 1, i)) * w + x];
                        for (let y = 0; y < h; y++) {
                            processedMask[y * w + x] = sum / diameter;
                            sum += tempMask[Math.min(h - 1, y + radius + 1) * w + x] - tempMask[Math.max(0, y - radius) * w + x];
                        }
                    }
                }
            }
            for (let i = 0; i < data.length; i += 4) data[i + 3] = processedMask[i / 4];
            ctx.putImageData(imageData, 0, 0);
            resolve(canvas.toDataURL());
        };
        img.onerror = (err) => reject(new Error("圖片載入失敗，無法執行去背。"));
        img.src = imageSrc;
    });
};

const refineAlphaChannel = (imageSrc, edgeOffset = 0, featherAmount = 0) => {
    return new Promise((resolve, reject) => {
        const img = new Image();
        img.crossOrigin = "Anonymous";
        img.onload = () => {
            const canvas = document.createElement('canvas');
            const w = img.width; const h = img.height;
            canvas.width = w; canvas.height = h;
            const ctx = canvas.getContext('2d', { willReadFrequently: true });
            ctx.drawImage(img, 0, 0);
            const imageData = ctx.getImageData(0, 0, w, h);
            const data = imageData.data;
            
            const mask = new Uint8Array(w * h);
            for (let i = 0; i < data.length; i += 4) {
                mask[i / 4] = data[i + 3];
            }

            let processedMask = mask;

            if (edgeOffset !== 0) {
                const iterations = Math.abs(Math.round(edgeOffset));
                let currentMask = processedMask;
                for (let i = 0; i < iterations; i++) {
                    const nextMask = new Uint8Array(currentMask.length);
                    for (let y = 1; y < h - 1; y++) {
                        for (let x = 1; x < w - 1; x++) {
                            const idx = y * w + x;
                            if (edgeOffset > 0) { // Dilate
                                let maxVal = 0;
                                for (let dy = -1; dy <= 1; dy++) for (let dx = -1; dx <= 1; dx++) maxVal = Math.max(maxVal, currentMask[(y + dy) * w + (x + dx)]);
                                nextMask[idx] = maxVal;
                            } else { // Erode
                                let minVal = 255;
                                for (let dy = -1; dy <= 1; dy++) for (let dx = -1; dx <= 1; dx++) minVal = Math.min(minVal, currentMask[(y + dy) * w + (x + dx)]);
                                nextMask[idx] = minVal;
                            }
                        }
                    }
                    currentMask = nextMask;
                }
                processedMask = currentMask;
            }

            if (featherAmount > 0) {
                const radius = Math.round(featherAmount);
                if (radius > 0) {
                    const tempMask = new Uint8Array(processedMask.length);
                    const diameter = radius * 2 + 1;
                    for (let y = 0; y < h; y++) {
                        let sum = 0;
                        for (let i = -radius; i <= radius; i++) sum += processedMask[y * w + Math.max(0, Math.min(w - 1, i))];
                        for (let x = 0; x < w; x++) {
                            tempMask[y * w + x] = sum / diameter;
                            sum += processedMask[y * w + Math.min(w - 1, x + radius + 1)] - processedMask[y * w + Math.max(0, x - radius)];
                        }
                    }
                    for (let x = 0; x < w; x++) {
                        let sum = 0;
                        for (let i = -radius; i <= radius; i++) sum += tempMask[Math.max(0, Math.min(h - 1, i)) * w + x];
                        for (let y = 0; y < h; y++) {
                            processedMask[y * w + x] = sum / diameter;
                            sum += tempMask[Math.min(h - 1, y + radius + 1) * w + x] - tempMask[Math.max(0, y - radius) * w + x];
                        }
                    }
                }
            }

            for (let i = 0; i < data.length; i += 4) data[i + 3] = processedMask[i / 4];
            
            ctx.putImageData(imageData, 0, 0);
            resolve(canvas.toDataURL());
        };
        img.onerror = (err) => reject(new Error("圖片載入失敗，無法優化 Alpha 頻道。"));
        img.src = imageSrc;
    });
};

const blurImage = (imageUrl, blurAmount) => {
    return new Promise((resolve, reject) => {
        const img = new Image();
        img.crossOrigin = 'Anonymous';
        img.onload = () => {
            const canvas = document.createElement('canvas');
            const w = img.width; const h = img.height;
            canvas.width = w; canvas.height = h;
            const ctx = canvas.getContext('2d');
            ctx.filter = `blur(${blurAmount}px)`;
            ctx.drawImage(img, 0, 0, w, h);
            resolve(canvas.toDataURL('image/png'));
        };
        img.onerror = (err) => reject(new Error("無法模糊圖片。"));
        img.src = imageUrl;
    });
};

const compositeWithChromaKey = (backgroundUrl, foregroundUrl, keyColor = 'green', tolerance = 40, edgeOffset = 0, featherAmount = 0) => {
    return new Promise((resolve, reject) => {
        const bgImg = new Image();
        const fgImg = new Image();
        bgImg.crossOrigin = 'Anonymous';
        fgImg.crossOrigin = 'Anonymous';

        let loadedCount = 0;
        const onBothLoaded = () => {
            if (++loadedCount < 2) return;

            const w = Math.max(bgImg.width, fgImg.width);
            const h = Math.max(bgImg.height, fgImg.height);
            const canvas = document.createElement('canvas');
            canvas.width = w;
            canvas.height = h;
            const ctx = canvas.getContext('2d');

            ctx.drawImage(bgImg, 0, 0, w, h);

            const fgCanvas = document.createElement('canvas');
            fgCanvas.width = w; fgCanvas.height = h;
            const fgCtx = fgCanvas.getContext('2d', { willReadFrequently: true });
            fgCtx.drawImage(fgImg, 0, 0, w, h);
            
            const fgImageData = fgCtx.getImageData(0, 0, w, h);
            const data = fgImageData.data;
            const keyColors = { green: [0, 255, 0], red: [255, 0, 0], blue: [0, 0, 255], black: [0, 0, 0] };
            const [kr, kg, kb] = keyColors[keyColor] || keyColors.green;
            
            const mask = new Uint8Array(w * h);
            for (let i = 0; i < data.length; i += 4) {
                const r = data[i], g = data[i + 1], b = data[i + 2];
                const distance = Math.sqrt(Math.pow(r - kr, 2) + Math.pow(g - kg, 2) + Math.pow(b - kb, 2));
                mask[i / 4] = (distance < tolerance * 2.55) ? 0 : 255;
            }

            let processedMask = mask;
            if (edgeOffset !== 0) {
                const iterations = Math.abs(Math.round(edgeOffset));
                let currentMask = processedMask;
                for (let i = 0; i < iterations; i++) {
                    const nextMask = new Uint8Array(currentMask.length);
                    for (let y = 1; y < h - 1; y++) {
                        for (let x = 1; x < w - 1; x++) {
                            const idx = y * w + x;
                            if (edgeOffset > 0) {
                                let maxVal = 0;
                                for (let dy = -1; dy <= 1; dy++) for (let dx = -1; dx <= 1; dx++) maxVal = Math.max(maxVal, currentMask[(y + dy) * w + (x + dx)]);
                                nextMask[idx] = maxVal;
                            } else {
                                let minVal = 255;
                                for (let dy = -1; dy <= 1; dy++) for (let dx = -1; dx <= 1; dx++) minVal = Math.min(minVal, currentMask[(y + dy) * w + (x + dx)]);
                                nextMask[idx] = minVal;
                            }
                        }
                    }
                    currentMask = nextMask;
                }
                processedMask = currentMask;
            }
            if (featherAmount > 0) {
                 const radius = Math.round(featherAmount);
                if (radius > 0) {
                    const tempMask = new Uint8Array(processedMask.length);
                    const diameter = radius * 2 + 1;
                    for (let y = 0; y < h; y++) {
                        let sum = 0;
                        for (let i = -radius; i <= radius; i++) sum += processedMask[y * w + Math.max(0, Math.min(w - 1, i))];
                        for (let x = 0; x < w; x++) {
                            tempMask[y * w + x] = sum / diameter;
                            sum += processedMask[y * w + Math.min(w - 1, x + radius + 1)] - processedMask[y * w + Math.max(0, x - radius)];
                        }
                    }
                    for (let x = 0; x < w; x++) {
                        let sum = 0;
                        for (let i = -radius; i <= radius; i++) sum += tempMask[Math.max(0, Math.min(h - 1, i)) * w + x];
                        for (let y = 0; y < h; y++) {
                            processedMask[y * w + x] = sum / diameter;
                            sum += tempMask[Math.min(h - 1, y + radius + 1) * w + x] - tempMask[Math.max(0, y - radius) * w + x];
                        }
                    }
                }
            }

            for (let i = 0; i < data.length; i += 4) {
                data[i + 3] = processedMask[i / 4];
            }
            fgCtx.putImageData(fgImageData, 0, 0);

            ctx.drawImage(fgCanvas, 0, 0);

            resolve(canvas.toDataURL('image/png'));
        };

        bgImg.onload = onBothLoaded;
        fgImg.onload = onBothLoaded;
        bgImg.onerror = () => reject(new Error("無法載入背景圖片。"));
        fgImg.onerror = () => reject(new Error("無法載入前景圖片。"));
        bgImg.src = backgroundUrl;
        fgImg.src = foregroundUrl;
    });
};

const addTextToImage = (imageUrl, texts) => {
    return new Promise((resolve, reject) => {
        const img = new Image();
        img.crossOrigin = 'Anonymous';
        img.onload = () => {
            const canvas = document.createElement('canvas');
            const scale = 2048 / img.width;
            canvas.width = 2048; canvas.height = img.height * scale;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
            const originalImageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
            const fullText = texts.join(' ');
            const colorPalettes = ['#FFD700', '#FF69B4', '#00FFFF', '#7FFF00', '#FFA500', '#FF6347', '#ff9a8b', '#f9d423', '#a2e5e8', '#84fab0', '#9face6', '#ffb3de'];
            ctx.fillStyle = colorPalettes[Math.floor(Math.random() * colorPalettes.length)];
            const baseFontSize = canvas.width / (fullText.length * 2.2 + 4.0);
            const fontSize = Math.max(canvas.width / 14, Math.min(canvas.width / 5, baseFontSize));
            const chineseFonts = [`900 ${fontSize}px "M PLUS Rounded 1c", "Noto Sans TC", sans-serif`, `bold ${fontSize * 1.2}px "Zhi Mang Xing", cursive`];
            ctx.font = chineseFonts[Math.floor(Math.random() * chineseFonts.length)];
            ctx.shadowColor = 'rgba(0, 0, 0, 0.75)'; ctx.shadowBlur = 10; ctx.shadowOffsetX = 3; ctx.shadowOffsetY = 3;
            const measuredWidth = ctx.measureText(fullText).width;
            let finalStyle;
            const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
            const data = imageData.data;
            let minX = canvas.width, minY = canvas.height, maxX = 0, maxY = 0;
            for (let y = 0; y < canvas.height; y++) for (let x = 0; x < canvas.width; x++) {
                if (data[(y * canvas.width + x) * 4 + 3] > 10) {
                    if (x < minX) minX = x; if (x > maxX) maxX = x;
                    if (y < minY) minY = y; if (y > maxY) maxY = y;
                }
            }
            if (maxX === 0 && minX === canvas.width) { minX = canvas.width*0.2; maxX = canvas.width*0.8; minY = canvas.height*0.1; maxY = canvas.height*0.9; }
            const subjectBounds = { left: minX, right: maxX, top: minY, bottom: maxY };
            const subjectWidth = subjectBounds.right - subjectBounds.left;
            const subjectHeight = subjectBounds.bottom - subjectBounds.top;
            const subjectCenterX = subjectBounds.left + subjectWidth / 2;
            let attempts = 0;
            while (attempts < 30) {
                const styleType = ['horizontal', 'arc', 'vertical'][Math.floor(Math.random() * 3)];
                let currentStyle;
                if (styleType === 'horizontal') {
                    const placement = Math.floor(Math.random() * 4);
                    let x, y, baseline;
                    if (placement === 0) { x = subjectBounds.left + Math.random() * subjectWidth; y = subjectBounds.top - fontSize * 0.5; baseline = 'bottom'; }
                    else if (placement === 1) { x = subjectBounds.left + Math.random() * subjectWidth; y = subjectBounds.bottom + fontSize * 1.2; baseline = 'top'; }
                    else if (placement === 2) { x = subjectBounds.left - measuredWidth / 2 - fontSize * 0.5; y = subjectBounds.top + Math.random() * subjectHeight; baseline = 'middle'; }
                    else { x = subjectBounds.right + measuredWidth / 2 + fontSize * 0.5; y = subjectBounds.top + Math.random() * subjectHeight; baseline = 'middle'; }
                    currentStyle = { type: 'horizontal', x, y, rot: (Math.random() - 0.5) * 30, baseline, align: 'center' };
                } else if (styleType === 'arc') { 
                     const direction = Math.random() > 0.5 ? 1 : -1;
                     const radius = subjectWidth * (0.4 + Math.random() * 0.4);
                     const cx = subjectCenterX + (Math.random() - 0.5) * (subjectWidth * 0.2);
                     const cy = direction === -1 ? subjectBounds.top + radius * (0.7 + Math.random() * 0.4) : subjectBounds.bottom - radius * (0.7 + Math.random() * 0.4);
                    currentStyle = { type: 'arc', direction, arcData: { cx, cy, radius } };
                } else {
                    const x = Math.random() > 0.5 ? subjectBounds.left - fontSize * 0.8 : subjectBounds.right + fontSize * 0.8;
                    const y = subjectBounds.top + Math.random() * Math.max(0, subjectHeight - ((fullText.length -1) * (fontSize * 1.1)));
                    currentStyle = { type: 'vertical', x, y, align: 'center', baseline: 'top' };
                }
                const tempCanvas = document.createElement('canvas'); tempCanvas.width = canvas.width; tempCanvas.height = canvas.height;
                const tempCtx = tempCanvas.getContext('2d'); tempCtx.font = ctx.font;
                drawTextOnCanvas(tempCtx, currentStyle, fullText, texts, canvas, measuredWidth, fontSize, true); 
                const textImageData = tempCtx.getImageData(0, 0, canvas.width, canvas.height);
                let overlapPixels = 0, textPixels = 0;
                for (let i = 0; i < textImageData.data.length; i += 4) {
                    if (textImageData.data[i+3] > 0) {
                        textPixels++;
                        if (originalImageData.data[i+3] > 10) overlapPixels++;
                    }
                }
                if ((textPixels > 0 ? overlapPixels / textPixels : 0) < 0.33) { finalStyle = currentStyle; break; }
                attempts++;
            }
            if (!finalStyle) finalStyle = { type: 'horizontal', align: 'center', baseline: 'bottom', x: subjectCenterX, y: subjectBounds.top - (fontSize * 0.2), rot: 0 };
            drawTextOnCanvas(ctx, finalStyle, fullText, texts, canvas, measuredWidth, fontSize, false);
            resolve(canvas.toDataURL('image/png'));
        };

        const drawTextOnCanvas = (ctx, style, fullText, texts, canvas, measuredWidth, fontSize, isChecking) => {
            const margin = fontSize * 0.5, lineHeight = fontSize * 1.1;
            if (style.type === 'horizontal') {
                const rotRad = (style.rot || 0) * Math.PI / 180;
                const rotatedWidth = measuredWidth * Math.abs(Math.cos(rotRad)) + (texts.length * lineHeight) * Math.abs(Math.sin(rotRad));
                const rotatedHeight = measuredWidth * Math.abs(Math.sin(rotRad)) + (texts.length * lineHeight) * Math.abs(Math.cos(rotRad));
                style.x = Math.max(rotatedWidth/2 + margin, Math.min(style.x, canvas.width - rotatedWidth/2 - margin));
                style.y = Math.max(rotatedHeight/2 + margin, Math.min(style.y, canvas.height - rotatedHeight/2 - margin));
            } else if (style.type === 'vertical') {
                style.x = Math.max(fontSize/2 + margin, Math.min(style.x, canvas.width - fontSize/2 - margin));
                style.y = Math.max(margin, Math.min(style.y, canvas.height - (fullText.length * lineHeight) - margin));
            } else if (style.type === 'arc' && style.arcData) {
                const effectiveRadius = style.arcData.radius + fontSize;
                style.arcData.cx = Math.max(effectiveRadius + margin, Math.min(style.arcData.cx, canvas.width - effectiveRadius - margin));
                style.arcData.cy = Math.max(effectiveRadius + margin, Math.min(style.arcData.cy, canvas.height - effectiveRadius - margin));
            }
            ctx.textAlign = style.align || 'center'; ctx.textBaseline = style.baseline || 'middle';
            const drawTextWithOutline = (text, x, y) => {
                if (isChecking) { ctx.fillText(text, x, y); return; }
                ctx.lineJoin = 'round';
                ctx.strokeStyle = '#FFFFFF'; ctx.lineWidth = fontSize / 5; ctx.strokeText(text, x, y);
                ctx.strokeStyle = '#000000'; ctx.lineWidth = fontSize / 15; ctx.strokeText(text, x, y);
                ctx.fillText(text, x, y);
            };
            ctx.save();
            if (style.type === 'arc' && style.arcData) {
                const { cx, cy, radius } = style.arcData;
                ctx.translate(cx, cy);
                ctx.rotate(- (measuredWidth / radius) / 2 * style.direction);
                for(const char of fullText) {
                    const anglePerChar = (ctx.measureText(char).width / radius);
                    ctx.rotate(anglePerChar / 2 * style.direction);
                    drawTextWithOutline(char, 0, -radius * style.direction);
                    ctx.rotate(anglePerChar / 2 * style.direction);
                }
            } else if (style.type === 'vertical') {
                ctx.translate(style.x || 0, style.y || 0);
                for (let i = 0; i < fullText.length; i++) drawTextWithOutline(fullText[i], 0, i * lineHeight);
            } else {
                ctx.translate(style.x || 0, style.y || 0); ctx.rotate((style.rot || 0) * Math.PI / 180);
                let startY = - (texts.length - 1) * lineHeight / 2;
                if (style.baseline === 'bottom') startY = -(texts.length - 1) * lineHeight; else if (style.baseline === 'top') startY = 0;
                texts.forEach((text, i) => drawTextWithOutline(text, 0, startY + (i * lineHeight)));
            }
            ctx.restore();
        };
        img.onerror = (err) => reject(new Error("無法載入圖片以添加文字"));
        img.src = imageUrl;
    });
};

const cropAndResizeToSquare = (imageUrl, size = 2048) => {
    return new Promise((resolve, reject) => {
        const img = new Image();
        img.crossOrigin = 'Anonymous';
        img.onload = () => {
            const canvas = document.createElement('canvas');
            canvas.width = size;
            canvas.height = size;
            const ctx = canvas.getContext('2d');
            
            const hRatio = canvas.width / img.width;
            const vRatio = canvas.height / img.height;
            const ratio = Math.min(hRatio, vRatio);

            const centerShift_x = (canvas.width - img.width * ratio) / 2;
            const centerShift_y = (canvas.height - img.height * ratio) / 2;

            ctx.clearRect(0, 0, canvas.width, canvas.height); // Make canvas transparent
            
            ctx.imageSmoothingEnabled = true;
            ctx.imageSmoothingQuality = 'high';
            ctx.drawImage(img, 0, 0, img.width, img.height,
                          centerShift_x, centerShift_y, img.width * ratio, img.height * ratio);
            
            resolve(canvas.toDataURL('image/png'));
        };
        img.onerror = (err) => reject(new Error("無法裁切並縮放圖片。"));
        img.src = imageUrl;
    });
};

const addSolidBackground = (imageUrl, color = '#00FF00') => {
    return new Promise((resolve, reject) => {
        const img = new Image();
        img.crossOrigin = 'Anonymous';
        img.onload = () => {
            const canvas = document.createElement('canvas');
            canvas.width = img.width;
            canvas.height = img.height;
            const ctx = canvas.getContext('2d');
            ctx.fillStyle = color;
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.drawImage(img, 0, 0);
            resolve(canvas.toDataURL('image/png'));
        };
        img.onerror = (err) => reject(new Error("無法添加純色背景。"));
        img.src = imageUrl;
    });
};

// --- 4. AI 提示詞產生器 (AI Prompt Generation) ---
// 集中管理所有用於生成 AI 圖片的複雜提示詞邏輯。

const getStyleInstruction = (style, realismValue = 100) => {
    switch (style) {
        case 'realistic':
            let description = (realismValue > 90) ? 'An ultra-realistic, hyper-detailed, high-quality photograph.' : (realismValue > 70) ? 'A realistic photograph with cinematic lighting and sharp focus.' : (realismValue > 50) ? 'A photorealistic digital painting, balancing realism with a slightly stylized, artistic feel.' : (realismValue > 30) ? 'A detailed digital painting in a painterly style. Resembles a high-quality piece of concept art.' : 'A beautiful oil painting with rich textures and visible, expressive brushstrokes. Leans towards classical or impressionistic art.';
            return `**Art Style:** ${description}\n**Likeness (CRITICAL):** Your absolute, number one priority is maximum likeness to the reference photo. The generated face MUST look exactly like the person in the photo. Do not alter their core facial features (eyes, nose, mouth shape, face structure). Replicate the face with extreme fidelity. The final result should be unmistakably the same person.`;
        case 'anime': return `**Art Style (Anime):** Your primary mission is to convert the subject into a Japanese anime style while strictly preserving their original identity.\n**Preservation Rules (CRITICAL - DO NOT CHANGE):**\n1.  **Clothing:** The clothing in the generated image MUST be identical to the clothing in the reference photo.\n2.  **Hairstyle:** The hairstyle (length, color, shape) MUST be identical to the hairstyle in the reference photo.\n3.  **Facial Structure:** The core facial structure must be maintained so the person is recognizable.\n\n**Stylistic Conversion (ONLY change these elements):**\n- **Facial Features Rendering (TOP PRIORITY):** This is your main focus. Redraw the EYES, nose, and mouth to have a distinct, expressive anime look. The EYES are the most critical element for capturing the style.\n- **Linework:** Convert all outlines and details into clean, sharp anime-style linework.\n- **Coloring & Shading:** Apply cel-shading or a modern soft-shading technique common in anime to the existing skin, hair, and clothes.\n- **Specific Artist Style:** If the user's prompt mentions a specific artist or studio (e.g., 'in the style of Studio Ghibli'), you must meticulously replicate that artist's unique approach to the elements above (eyes, lines, color).`;
        default: return `**Art Style (Chibi):** Your primary mission is to convert the subject into a cute "chibi" or "Q-version" cartoon style while strictly preserving their original identity.\n**Preservation Rules (CRITICAL - DO NOT CHANGE):**\n1.  **Clothing:** The clothing in the generated image MUST be identical to the clothing in the reference photo.\n2.  **Hairstyle:** The hairstyle (length, color, shape) MUST be identical to the hairstyle in the reference photo.\n\n**Stylistic Conversion (ONLY change these elements):**\n- **Proportions:** Redraw the subject with classic chibi proportions: a large, oversized head and a small, simplified body.\n- **Facial Features Rendering (TOP PRIORITY):** Redraw the EYES, nose, and mouth to be large, expressive, and cute, fitting the chibi aesthetic. The EYES are the most critical element.\n- **Simplification:** Simplify details on the preserved clothing and hair to fit the clean, cute chibi look.\n- **Linework & Shading:** Apply clean linework and simple, often vibrant, cel-shading.\n- **Specific Artist Style:** If the user's prompt mentions a specific artist or brand (e.g., 'in the style of Sanrio', 'like a Funko Pop'), you must meticulously replicate that artist's unique approach to the elements above (proportions, eyes, lines, color).`;
    }
};

const getNegativePrompts = (style, negativePrompt, textMode, prompt) => {
    let base = style === 'realistic' ? "anime, cartoon, 3D, CGI, illustration, painting, drawing, plastic skin, blurry, deformed, disfigured, poor quality, bad anatomy, worst quality, low quality, extra limbs, extra fingers, fused fingers, too many fingers, third hand" : "photograph, realistic, 3D, blurry, deformed, disfigured, poor quality, bad anatomy, worst quality, low quality, extra limbs, extra fingers, fused fingers, too many fingers, watermark, signature, third hand";
    if (negativePrompt) base += `, ${negativePrompt}`;
    if (textMode !== 'english' || !prompt?.memeTextEN) base += ", text, letters, characters, fonts";
    return `**NEGATIVE PROMPTS:** ${base}`;
};

const getTextInstruction = (style, textMode, prompt) => {
    if (textMode === 'english' && prompt?.memeTextEN) {
        const textToRender = prompt.memeTextEN;
        let instruction = '';
        switch (style) {
            case 'realistic': instruction = `Render the exact text "${textToRender}" at the bottom center of the image. Use a clean, modern, sans-serif font. The text must be white with a subtle black outline or drop shadow for maximum readability.`; break;
            case 'anime': instruction = `Render the exact text "${textToRender}" in a dynamic, bold, comic-book style font. Place it in one of the corners of the image, slightly rotated. The text should have a vibrant color (like yellow or cyan) and a thick black outline.`; break;
            default: instruction = `Render the exact text "${textToRender}" using a cute, rounded, playful font (like a bubble font). Place it creatively near the character, possibly in an arc or at a fun angle. The text must be colorful and have a friendly appearance with a contrasting outline.`; break;
        }
        return `**Text Generation (CRITICAL):** ${instruction}`;
    }
    return `**Text Generation (CRITICAL):** It is absolutely critical that you DO NOT add any text, letters, characters, or fonts to the image itself. The image must be completely free of any text.`;
};

const getFramingInstruction = (style, framingMode, applyBottomCrop) => {
    let header = `\n\n**Framing & Composition (CRITICAL COMMAND):**`;
    if (style === 'chibi') header += `\n- **Chibi Style Proportions Note:** You are drawing a 'chibi' character with a large head and small body. You MUST still follow the framing mode below, but interpret it for these unique proportions. For example, a 'chest-up' shot will show the large head and only the very top part of the tiny torso. A 'half-body' shot will show the head and most of the small body. The user's intent is to control how much of the small body is visible.`;
    let composition = header + `\n- **Subject Composition (CRITICAL):** The subject should be positioned centrally. A very generous amount of empty background space must surround the subject on all sides, creating a large, clear margin between the subject and the edges of the image. The subject must not feel crowded by the frame.\n- **Head Integrity (ABSOLUTE CRITICAL):** The entire head, including all hair, ears, and accessories, MUST be fully visible within the frame. Absolutely NO part of the head should be cropped or touch the edge of the image. This is the most important rule.\n- **No Cropping Rule:** Ensure no part of the subject (hair, ears, hands, clothing, props) is cropped or cut off by the edges of the image.\n- **FRAMING MODE:** You MUST strictly adhere to the selected framing mode:`;
    let modeInstruction = '';
    switch (framingMode) {
        case 'headshot': modeInstruction = `\n  - **Headshot (EXTREME CLOSE-UP):** This is the tightest possible framing. The frame MUST cut off the subject's chin at the bottom and forehead/hair at the top. ONLY the face should be visible. CRITICAL: The neck and shoulders are absolutely forbidden and MUST NOT be visible. This is a pure facial portrait.`; break;
        case 'chest': modeInstruction = `\n  - **Chest-Up (VERY STRICT):** The framing MUST be extremely tight, from the collarbone or neck up. ONLY the head and neck are allowed. CRITICAL: The shoulders MUST be completely cut off. Any part of the body below the neck (shoulders, chest, arms) is strictly forbidden and must not be visible.`; break;
        case 'halfBody': modeInstruction = `\n  - **Half-Body (VERY STRICT):** The framing MUST be from the middle of the chest up. It includes the head and shoulders. CRITICAL: The bottom edge of the frame MUST cut off the subject around the sternum or mid-chest area. The waist, stomach, or hips are strictly forbidden and must not be visible.`; break;
        default: modeInstruction = `\n  - **Default (Full Subject):** The composition should be based on the original reference photo's framing, but ensure the entire subject is visible within the frame without being cut off.`; break;
    }
    let bottomTreatment = '';
    if (applyBottomCrop && framingMode !== 'headshot') bottomTreatment = `\n- **Bottom Treatment (Stylistic Crop):** If the subject's torso is visible, apply a clean, smooth, downward-curving arc or a sharp V-shape crop to the bottom of the torso to create a stylized bust effect.`;
    else if (framingMode === 'chest' || framingMode === 'halfBody') bottomTreatment = `\n- **Bottom Treatment (Extend to Edge):** The subject's body MUST extend downwards until it is naturally cropped by the bottom edge of the image frame. The end of the torso must not be visible; it must go out of the frame.`;
    else bottomTreatment = `\n- **Bottom Treatment (Full View):** The entire subject, including their lower body part as defined by the framing mode, must be fully visible within the image frame. Do not force the subject to align with the bottom edge; allow for natural spacing and composition.`;
    return composition + modeInstruction + bottomTreatment;
};

const getBackgroundInstruction = (removeBackground, chromaKeyColor = 'green') => {
    if (removeBackground) {
        const colors = { green: { rgb: '(0, 255, 0)', name: 'green screen green' }, red: { rgb: '(255, 0, 0)', name: 'pure red' }, blue: { rgb: '(0, 0, 255)', name: 'pure blue' }, black: { rgb: '(0, 0, 0)', name: 'pure black' }, };
        const selectedColor = colors[chromaKeyColor] || colors.green;
        return `**Background (CRITICAL):** The background MUST be a solid, pure, flat ${selectedColor.name} with the exact RGB value of ${selectedColor.rgb}. The subject must be fully rendered against this background with no shadows or color spill onto the subject.`;
    }
    return `**Background:** Generate a simple, non-distracting background that complements the subject and expression.`;
};

const getModelInstruction = ({ prompt, removeBackground, addWhiteBorder, customPrompt, style, negativePrompt, framingMode, hasStyleReference, rotation = { h: 0, v: 0 }, textMode, applyBottomCrop, realismValue = 100, chromaKeyColor, gender, personCount }) => {
    const instructions = [];
    if (hasStyleReference) instructions.push(`**Style Reference & Imitation Hierarchy (ABSOLUTE TOP PRIORITY):**\n- The VERY LAST image provided is a style reference. Your primary goal is to meticulously replicate the art style of this reference image.\n- You MUST follow this specific hierarchy of importance when imitating the style:\n  1.  **Facial Feature Rendering (Most Important):** First and foremost, replicate the way the eyes, nose, and mouth are drawn. This is the most critical part of the style imitation.\n  2.  **Linework & Shading:** Second, mimic the style of the line art (e.g., thickness, texture) and the method of shading (e.g., cel-shading, soft gradients, cross-hatching).\n  3.  **Coloring & Brushstrokes:** Third, adopt the color palette and the texture of the brushstrokes or rendering from the reference.\n  4.  **Body Proportions:** Finally, adjust the body proportions of the subject to match the style reference, but only after the above points are perfectly achieved.\n- **CRITICAL - What NOT to copy:**\n  - DO NOT copy the POSE, EXPRESSION, or CLOTHING from the style reference. The pose and expression must match the text prompt, and the clothing should be based on the primary subject photos.\n  - The subject's LIKENESS (their personal identity) must still come from the primary subject photo(s) provided at the beginning.`);
    let basePromptText = (prompt.id === '難過' && style === 'realistic') ? 'A devastatingly sad expression, with wide, sorrowful eyes. A single, clear line of tears runs down each cheek, stopping on the face. The expression must be restrained and hyper-realistic. The mouth should be slightly downturned. The whole face should convey deep sorrow. No hands should be visible.' : prompt.base;
    instructions.push(`Create an expressive 1:1 image for the action: "${basePromptText}".`);
    let userPrompts = `\n\n**User Prompts (Highest Priority):**\n- **Likeness:** Maintain the exact facial features and likeness from the reference photo(s).`;
    if (personCount > 1) {
        userPrompts += `\n- **Multiple People Detected (${personCount}):** This image contains ${personCount} people. You MUST include all ${personCount} people in the final output, maintaining the likeness and relative positions of each individual.`;
    }
    if (gender && gender !== 'unknown') {
        const genderText = gender === 'female' ? 'female, woman, girl' : 'male, man, boy';
        userPrompts += `\n- **Gender (CRITICAL):** The subject is a ${genderText}. All generated features must be consistent with this gender.`;
    }
    if (customPrompt) userPrompts += `\n- **Positive Prompts:** ${customPrompt}`;
    userPrompts += `\n- ${getNegativePrompts(style, negativePrompt, textMode, prompt)}`;
    instructions.push(userPrompts);
    instructions.push(`\n${getStyleInstruction(style, realismValue)}`);
    instructions.push(`\n${getTextInstruction(style, textMode, prompt)}`);
    instructions.push(getFramingInstruction(style, framingMode, applyBottomCrop));
    const angleInstructions = [];
    if (rotation.h !== 0) angleInstructions.push(`turned ${Math.abs(rotation.h * 45)} degrees to the ${rotation.h > 0 ? 'right' : 'left'}`);
    if (rotation.v !== 0) angleInstructions.push(`tilted head ${rotation.v > 0 ? 'up' : 'down'} by ${Math.abs(rotation.v * 45)} degrees`);
    if (angleInstructions.length > 0) instructions.push(`**Viewing Angle:** The subject is ${angleInstructions.join(" and ")}.`);
    instructions.push(addWhiteBorder ? `**Outline:** EXTREMELY IMPORTANT: Add a clean, thick white outline around the subject.` : `**Outline:** EXTREMELY IMPORTANT: There must be absolutely NO white outline around the subject.`);
    instructions.push(`\n${getBackgroundInstruction(removeBackground, chromaKeyColor)}`);
    instructions.push(`\n**Output:** A high-quality 2048x2048 pixel PNG.`);
    return instructions.join('\n');
};

// --- 5. 靜態設定檔 (Static Configuration) ---
// 存放不會在執行期間變動的資料，例如貼圖定義、UI設定等。

const SPLIT_SOURCES = {
    heartPair: { id: 'heartPair_source', base: "A two-person shot featuring the subject and their identical clone side-by-side. The person on the left uses their **right hand** to form the right half of a large heart. The person on the right uses their **left hand** to form the left half. Their hands meet in the center to create one complete, perfect heart. Both have happy, adoring expressions. CRITICAL: The final image must contain two identical people forming one complete heart together. NEGATIVE PROMPTS: single person, incomplete heart, finger heart, thumb heart." },
    thumbsUpPair: { id: 'thumbsUpPair_source', base: "A two-person shot featuring the subject and their identical clone side-by-side, both with bright, confident smiles. The person on the left gives a clear thumbs-up with their **RIGHT hand**, pointing towards the center. The person on the right gives a clear thumbs-up with their **LEFT hand**, pointing towards the center. Both are near the center line. CRITICAL: The final image must contain two identical people giving thumbs-up towards each other. NEGATIVE PROMPTS: single person." },
    posePair: { id: 'posePair_source', base: "**POSE HIERARCHY (ABSOLUTE HIGHEST PRIORITY - NON-NEGOTIABLE):** This pose has a strict order of importance. You MUST prioritize the following instructions in the order they are given. Any deviation will result in a failed image.\n1.  **INNER ELBOW CONTACT (THE PRIMARY, MOST IMPORTANT GOAL):** A two-person shot, subject and clone side-by-side. The single most critical objective is that the inner elbow of the left person (right elbow) and the inner elbow of the right person (left elbow) MUST extend forward and inwards to touch each other PERFECTLY and PRECISELY on the vertical center line of the image. There must be absolutely no gap. These two meeting elbows form the sharp bottom point of a heart shape. All other aspects of the pose must be adjusted to achieve this perfect elbow connection. This is the number one, non-negotiable requirement.\n2.  **HAND GESTURE & ARM POSITIONING (SECONDARY, BUT STILL MANDATORY):**\n    - **Hand Shape:** BOTH hands on BOTH people MUST be held perfectly straight with all four fingers pressed tightly together, forming a 'knife hand' or 'blade' shape. This is the second highest priority after the elbow connection.\n    - **Inner Arms:** To achieve the elbow connection, the inner forearm (right arm for the left person, left arm for the right person) crosses the chest to place the 'knife hand' on the opposite shoulder. The palm of this hand should face the body.\n    - **Outer Arms (Top of Heart):** The outer arm (left arm for the left person, right arm for the right person) is raised high in a wide, smooth arc over the head. The 'knife hand' continues this arc, and the fingertips of both outer hands MUST meet at the top center to form the cleft of the heart.\n3.  **GENERAL COMPOSITION (SUPPORTING DETAILS):**\n    - **Viewing Angle:** Both individuals MUST be facing directly forward, looking at the camera.\n    - **Upper Body Posture:** Maintain a mostly upright posture, turning shoulders slightly inwards only as needed to achieve the primary elbow connection goal.\n    - **Symmetry:** The entire pose must be graceful and perfectly symmetrical.\n    - **Leg Position:** Adopt a stable, wide stance.\n**NEGATIVE PROMPTS:** elbows not touching, gap between elbows, elbows off-center, incorrect hand gesture, asymmetrical, hands not touching, open palms, third person, standing straight, broken heart shape." },
    fusionPair: { id: 'fusionPair_source', base: "A two-person shot, subject and clone, side-by-side, striking a symmetrical, mirrored action pose. **VIEWING ANGLE (CRITICAL):** Both individuals MUST be facing directly forward, looking straight at the camera. **UPPER BODY POSTURE (CRITICAL):** To reach the center, their upper bodies must lean significantly inwards toward each other. There should be a clear, symmetrical curve in their spines as they stretch to make the pose connect. **HAND GESTURE (ABSOLUTELY CRITICAL, TOP PRIORITY):** The hand gesture is the most important part of this pose. BOTH hands on BOTH people MUST be PERFECTLY clenched into a fist, with ONLY the index finger extended straight out. No other fingers should be visible or partially extended. This rule is non-negotiable. **ARM & FINGER POSITIONING (EQUALLY CRITICAL):** The precise positioning of the arms and fingers is mandatory. - **Outer Arms:** The outer arm (left arm for the person on the left, right arm for the right person) is raised high and bent inwards, passing over their head. The extended index finger points towards the center line. - **Inner Arms (EXTREMELY IMPORTANT - SPATIAL RELATIONSHIP):** The inner upper arm MUST be retracted downwards and pulled in tightly against the side of the body. The elbow should be positioned at the waist, slightly behind the torso's frontal plane. From this tucked position, the forearm bends sharply and extends forward, parallel to the ground, pointing directly towards the center line. - **FINGER INTERACTION (MANDATORY - TARGET POINT):** The target for the fingertips is the exact vertical center line of the entire image, which is the seam where the two individuals meet. The tips of the inner index fingers (right finger of left person, left finger of right person) MUST extend horizontally towards each other and touch *perfectly* on this central line. Similarly, the tips of the outer index fingers MUST meet and touch *perfectly* on this central line, high above their heads. There must be absolutely no gap between the fingertips. **LEG POSITION:** They are in a stable, wide stance with their knees slightly bent, not a deep lunge. The entire pose must be powerful and perfectly symmetrical. **NEGATIVE PROMPTS:** incorrect pose, incorrect hand gesture, asymmetrical, fingers not touching, gap between fingers, fingers off-center, open hands, third person, standing straight, straight spine, upright body, deep lunge, side view, profile view, inner arm in front of the body, full inner arm visible, inner elbow in front of torso, inner arm extended from shoulder." }
};

const GENERATION_PROMPTS = [
    { id: '開心', base: 'a happy, joyful, smiling expression. No hands are visible in the frame.', memeTextEN: 'HAHA', memeTextZH: '哈哈' }, { id: '比耶', base: 'a happy, excited expression while making a V-sign (peace sign) with one hand to the side of the head, ensuring the hand does not obstruct the face.', memeTextEN: 'YA', memeTextZH: '耶' }, { id: '說嗨', base: 'a happy, cheerful expression while waving one hand (a standard five-finger wave gesture), ensuring the hand does not obstruct the face.', memeTextEN: 'Hi', memeTextZH: '嗨' }, { id: '愛心', base: 'an adoring expression with a gentle, warm smile, making a large heart shape with both hands (a hand heart or arm heart). CRITICAL: The gesture made by crossing the thumb and index finger, known as a "finger heart", is ABSOLUTELY AND STRICTLY FORBIDDEN. The hands must form a large, two-handed heart and be well below the chin, not obstructing the face. NEGATIVE PROMPTS: finger heart, thumb heart.', memeTextEN: 'UWU', memeTextZH: '大心' }, { id: '比愛', base: '和另一個人比出一個完整愛心的右半邊。', splitFrom: 'heartPair', useHalf: 'left', memeTextEN: 'Love', memeTextZH: '愛', alignEdge: 'left' }, { id: '比心', base: '和另一個人比出一個完整愛心的左半邊。', splitFrom: 'heartPair', useHalf: 'right', memeTextEN: '', memeTextZH: '心', alignEdge: 'right' }, { id: '比讚', base: '和另一個人一起比讚，這是左半邊的圖。', splitFrom: 'thumbsUpPair', useHalf: 'left', memeTextEN: 'Good', memeTextZH: '讚', alignEdge: 'left' }, { id: '比棒', base: '和另一個人一起比讚，這是右半邊的圖。', splitFrom: 'thumbsUpPair', useHalf: 'right', memeTextEN: 'Nice', memeTextZH: '棒', alignEdge: 'right' }, { id: '大愛', base: '用手臂和另一個人比出一個大愛心的右半邊。', splitFrom: 'posePair', useHalf: 'left', memeTextEN: 'LOVE', memeTextZH: '愛', alignEdge: 'left' }, { id: '大心', base: '用手臂和另一個人比出一個大愛心的左半邊。', splitFrom: 'posePair', useHalf: 'right', memeTextEN: 'HEART', memeTextZH: '心', alignEdge: 'right' }, { id: '比融', base: '與另一個人擺出對稱的融合姿勢，這是左半邊。', splitFrom: 'fusionPair', useHalf: 'left', memeTextEN: 'Fusion', memeTextZH: '融', alignEdge: 'left' }, { id: '比合', base: '與另一個人擺出對稱的融合姿勢，這是右半邊。', splitFrom: 'fusionPair', useHalf: 'right', memeTextEN: '', memeTextZH: '合', alignEdge: 'right' }, { id: '很讚', base: 'A happy, confident expression, giving a clear thumbs-up with one hand. The hand does not obstruct the face.', memeTextEN: 'Great!', memeTextZH: '讚' }, { id: '思考', base: 'a thoughtful expression with a finger gently touching the chin and a focused thinking face, not covering the mouth, looking upwards.', memeTextEN: 'Hmm...', memeTextZH: '嗯‧‧' }, { id: '問號', base: "A character facing the camera with a confused expression. One hand is held out, palm up, in a gesture as if cupping or holding something. Generate a single large, prominent, glowing yellow question mark floating directly above the open palm. The question mark MUST have a friendly, rounded, bubbly font style.", memeTextEN: '?', memeTextZH: '' }, { id: '拜託', base: 'a pleading expression with large, pleading puppy-dog eyes. CRITICAL: The expression must be imploring and cute, but absolutely NOT sad or crying. The eyes must be wide and hopeful, with no tears. The hands are clasclasped together in front of the chest, well below the chin, not obstructing the face. NEGATIVE PROMPT: tears, crying, sad.', memeTextEN: 'Pls?', memeTextZH: '霸託' }, { id: '傷心', base: 'a pitiful expression, trying very hard to hold back tears. The eyes are glistening and full of water, but absolutely NO tears are rolling down the cheeks. The lower lip is quivering. The hands should not be visible. NEGATIVE PROMPT: streaming tears, crying hard.', memeTextEN: 'SO SAD', memeTextZH: '嚶嚶' }, { id: '難過', base: 'A devastatingly sad expression, with heavy streams of tears flowing down the cheeks from wide, sorrowful eyes, but the tears MUST NOT go past the chin. The mouth should be open in a wail. The whole face should convey extreme sorrow. No hands should be visible.', memeTextEN: 'SNIFF...', memeTextZH: '嗚嗚' }, { id: '手勢', base: 'an annoyed, defiant expression, raising the middle finger. The hand gesture should be clear but not the sole focus.', memeTextEN: 'Fxxk', memeTextZH: '看' }, { id: '生氣', base: 'an angry expression. No hands are visible.', memeTextEN: 'GRRR', memeTextZH: '啥小' }, { id: '咆哮', base: 'an angry, menacing expression, baring teeth and snarling. Both hands are raised and spread open like claws in a threatening gesture.', memeTextEN: 'Ouch', memeTextZH: '嗷嗚' }, { id: '害怕', base: 'a terrified, fearful expression with wide, scared eyes. The character is hugging their own upper arms tightly as if trying to protect themselves.', memeTextEN: 'Scared', memeTextZH: '怕' }, { id: '欠揍', base: 'A funny, exaggeratedly angry expression, like a comical villain. The body is turned to the side, one arm is raised high with the elbow pulled far back, holding a fist near the side of the face, ready to strike a comical punch. The four fingers of the fist should be visible, facing forward towards the viewer. The expression is more playful than genuinely threatening.', memeTextEN: 'Punch', memeTextZH: '欠揍' }, { id: '得意', base: 'a proud, complacent expression with both hands on hips, chest puffed out slightly, and legs slightly apart in a confident stance.', memeTextEN: 'Proud', memeTextZH: '志得意滿' }, { id: '哈欠', base: 'a sleepy expression with drowsy, half-closed eyes, caught mid-yawn with one hand delicately covering only the mouth, making sure the hand does not cover the nose or eyes.', memeTextEN: 'YAWN', memeTextZH: '哈欠' }, { id: '睡覺', base: 'sleeping peacefully with eyes closed, head tilted slightly to one side. Both hands are clasped together and placed against the cheek, as if being used as a pillow. IMPORTANT: ONLY for the chibi style, include a large, comically exaggerated, pulsating snot bubble coming from one nostril. Other styles must NOT have a snot bubble.', memeTextEN: '.zZ', memeTextZH: '呼嚕嚕' }, { id: '大笑', base: 'An exaggerated, hearty laugh with the head tilted back slightly. No hands are visible in the frame.', memeTextEN: 'Wahaha', memeTextZH: '笑死' }, { id: '驕笑', base: 'A triumphant, hearty laugh. **POSE (ABSOLUTE TOP PRIORITY - THIS ENTIRE DESCRIPTION MUST BE FOLLOWED EXACTLY AND IS NON-NEGOTIABLE):** The LEFT forearm MUST cross the chest, bringing the left hand near the right side of the face. The LEFT hand\\\'s wrist MUST be bent sharply upwards, so the palm faces upwards. The RIGHT forearm must cross the body LOW, at the waistline, so the RIGHT hand is holding the LEFT waist. The right hand MUST remain at or below the level of the left elbow. **EXPRESSION (CRITICAL):** The expression must be proud and joyful. The eyes are the most critical part of this expression and must be rendered precisely. **EYE SHAPE (ABSOLUTE COMMAND):** The eyes must be distinctly open, shaped like a calm, horizontal crescent or almond. They are NOT squinting. A significant portion of the iris and pupil MUST be visible. The upper eyelid should be relaxed, not squeezed down. The eyes convey arrogance and amusement, not the physical action of laughing. CRITICAL COMMAND: Under no circumstances should the eyes be rendered as simple lines, slits, or fully closed crescents. They MUST remain visibly open. NEGATIVE PROMPTS: closed eyes, eyes shut, smiling eyes, crinkled eyes, squinting, eyes as lines.', memeTextEN: 'oh-ho~ho', memeTextZH: '喔呵呵' }, { id: '驚訝', base: 'a shocked, surprised expression with wide eyes and open mouth, like "wow". No hands are visible.', memeTextEN: 'WOW!', memeTextZH: '蛤' },
];

const UI_STICKER_CONFIG = [
    { id: '愛&心', members: ['比愛', '比心'] }, { id: '讚&棒', members: ['比讚', '比棒'] }, { id: '大&心', members: ['大愛', '大心'] }, { id: '融&合', members: ['比融', '比合'] }, { id: '開心' }, { id: '比耶' }, { id: '說嗨' }, { id: '愛心' }, { id: '很讚' }, { id: '思考' }, { id: '問號' }, { id: '拜託' }, { id: '傷心' }, { id: '難過' }, { id: '手勢' }, { id: '生氣' }, { id: '咆哮' }, { id: '害怕' }, { id: '欠揍' }, { id: '得意' }, { id: '大笑' }, { id: '驕笑' }, { id: '驚訝' }, { id: '哈欠' }, { id: '睡覺' },
];

const ALL_GENERATABLE_IDS = GENERATION_PROMPTS.map(p => p.id);

