                const { mimeType, data: imageWithoutPrefix } = processDataUrl(uploadedImage); if (!mimeType || !imageWithoutPrefix) throw new Error("無效的圖片格式。");
                const payload = { contents: [{ parts: [ { text: basePrompt + genderPrompt }, { inlineData: { mimeType, data: imageWithoutPrefix } } ] }], generationConfig: { responseModalities: ['TEXT', 'IMAGE'] } };
                const resizedImageUrl = await resizeImage(await generateImageWithRetry(payload), 2048, 2048);
                setImageHistory(prev => { const newHistory = prev.slice(0, historyIndex + 1); newHistory.push({ url: resizedImageUrl, properties: null }); return newHistory; });
                setHistoryIndex(prev => prev + 1); setGeneratedImages([]);
                return;
