                                                                                    </g>

                                                                                    {/* Nose */}
                                                                                    <path d={`M ${g.centerX - 1} ${g.noseY} Q ${g.centerX} ${g.noseY + 2} ${g.centerX + 1} ${g.noseY}`} strokeWidth="0.5" opacity={op('facial_features', ['鼻子'])} />

                                                                                    {/* Mouth */}
                                                                                    <g opacity={op('facial_features', ['嘴巴'])}>
                                                                                        <path d={`M ${g.centerX - g.mouthDx} ${g.mouthY + g.mouthCornerDy} Q ${g.centerX} ${g.mouthY - g.mouthUpperDy} ${g.centerX + g.mouthDx} ${g.mouthY + g.mouthCornerDy}`} strokeWidth="0.5" />
                                                                                        <path d={`M ${g.centerX - g.mouthDx + 2} ${g.mouthY + g.mouthCornerDy + 1} Q ${g.centerX} ${g.mouthY + g.mouthLowerDy} ${g.centerX + g.mouthDx - 2} ${g.mouthY + g.mouthCornerDy + 1}`} strokeWidth="0.5" opacity="0.6" />
                                                                                    </g>
                                                                                </svg>
                                                                            </div>
                                                                        );})()}

                                                                        <div className="absolute inset-0 z-30 touch-none overflow-hidden">
