                                                                                        <circle cx={g.centerX - g.eyeCenterDx} cy={g.eyeY} r={Math.max(0.5, g.eyeDy * 0.3)} fill="currentColor" opacity="0.8" />
                                                                                        
                                                                                        <path d={`M ${g.centerX + g.eyeCenterDx - g.eyeDx} ${g.eyeY} Q ${g.centerX + g.eyeCenterDx} ${g.eyeY - g.eyeDy*1.5} ${g.centerX + g.eyeCenterDx + g.eyeDx} ${g.eyeY}`} strokeWidth="0.8" />
                                                                                        <path d={`M ${g.centerX + g.eyeCenterDx - g.eyeDx + 1} ${g.eyeY + g.eyeDy*0.5} Q ${g.centerX + g.eyeCenterDx} ${g.eyeY + g.eyeDy} ${g.centerX + g.eyeCenterDx + g.eyeDx - 1} ${g.eyeY + g.eyeDy*0.5}`} strokeWidth="0.4" />
                                                                                        <circle cx={g.centerX + g.eyeCenterDx} cy={g.eyeY} r={Math.max(0.5, g.eyeDy * 0.3)} fill="currentColor" opacity="0.8" />
                                                                                    </g>

                                                                                    {/* Eyebrows */}
                                                                                    <g opacity={op('facial_features', ['眉毛'])}>
