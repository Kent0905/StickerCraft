                    const ix = (ib.x / 100) * img.width;
                    const iy = (ib.y / 100) * img.height;
                    const iw = (ib.w / 100) * img.width;
                    const ih = (ib.h / 100) * img.height;

                    const nx = (nb.x / 100) * img.width;
                    const ny = (nb.y / 100) * img.height;
                    const nw = (nb.w / 100) * img.width;
                    const nh = (nb.h / 100) * img.height;

