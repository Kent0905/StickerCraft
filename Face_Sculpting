<body class="bg-black text-white">
    <div id="root"></div>

    <script>
        window.UI_STICKER_CONFIG = window.UI_STICKER_CONFIG || [
            { id: '正面' }, { id: '左側' }, { id: '右側' }, { id: '頭像' }, { id: '胸像' },
            { id: '一般' }, { id: '微笑' }, { id: '大笑' }, { id: '生氣' }, { id: '難過' }
        ];

        window.BUILTIN_MODELS = window.BUILTIN_MODELS || [
            { id: 'model_custom_1', name: '素體模型', url: 'https://jsd.onmicrosoft.cn/gh/Kent0905/StickerCraft@main/02.svg' },
            { id: 'model_base_m', name: '標準男模', url: 'data:image/svg+xml;base64,' },
            { id: 'model_base_f', name: '標準女模', url: 'data:image/svg+xml;base64,' }
        ];

        window.GENERATION_PROMPTS = window.GENERATION_PROMPTS || [
            { id: '正面', base: 'Front-facing portrait. Perfectly symmetrical. No rotation. Neutral or slight smile.', memeTextEN: '', memeTextZH: '' },
            { id: '左側', base: "Perfect 90-degree profile shot, character is facing the left side of the frame.", memeTextEN: '', memeTextZH: '' },
            { id: '右側', base: "90-degree profile shot, character is facing the right side of the frame.", memeTextEN: '', memeTextZH: '' },
            { id: '頭像', base: "EXTREME CLOSE-UP MACRO SHOT OF THE FACE AND HEAD ONLY. The camera is very close to the face. The neck MUST seamlessly connect to the exact bottom edge of the image frame. NO empty space below the neck. NOT floating.", memeTextEN: '', memeTextZH: '' },
            { id: '胸像', base: "Front-facing bust portrait, chest-up shot. Head, shoulders, and chest maximally fill the frame. The chest MUST seamlessly connect to the exact bottom edge of the image frame. NO empty space below the subject. NOT floating.", memeTextEN: '', memeTextZH: '' },
            { id: '一般', base: 'Neutral, expressionless, natural look.', memeTextEN: '', memeTextZH: '' },
            { id: '微笑', base: 'Gentle, genuine happy smile.', memeTextEN: 'Smile', memeTextZH: '微笑' },
            { id: '大笑', base: 'Laughing out loud, wide open mouth, very happy, eyes squeezed shut from laughing.', memeTextEN: 'Haha!', memeTextZH: '大笑' },
            { id: '生氣', base: 'Angry, furious, strongly furrowed brows, glaring, fierce expression.', memeTextEN: 'Angry', memeTextZH: '生氣' },
            { id: '難過', base: 'Sad, sorrowful, crying, tears. NO hands touching face.', memeTextEN: 'Sad', memeTextZH: '難過' }
        ];

        window.PIXEL_LEVELS = window.PIXEL_LEVELS || { fc:{label:'FC',resolution:240,colors:25}, sfc:{label:'SFC',resolution:256,colors:128}, ps:{label:'PS',resolution:480,colors:null}, pc:{label:'PC',resolution:1024,colors:null}, 'hd-2d':{label:'HD-2D',resolution:1024,colors:null} };
        window.SUBSTYLE_LABELS = window.SUBSTYLE_LABELS || { '3d-chibi':'3D Q版', 'anime':'動漫', 'realistic':'寫實' };
        window.LIGHT_TYPES = window.LIGHT_TYPES || { '無': '', '泛光': 'omni light, point light source', '日光': 'bright natural sunlight', '聚光': 'dramatic spotlight effect', '蘋果光': 'beauty light effect', '夜光': 'nighttime lighting' };
        window.LIGHT_ANGLES = window.LIGHT_ANGLES || { '前': 'front', '後': 'back', '左': 'left', '右': 'right', '上': 'top overhead', '下': 'extreme underlighting' };
        window.LIGHT_TONES = window.LIGHT_TONES || { '無': '', '冷': 'cool color temperature', '暖': 'warm color temperature', '紅': 'red', '藍': 'blue', '綠': 'green', '黃': 'yellow', '橙': 'orange', '紫': 'purple' };
        window.LIGHT_INTENSITIES = window.LIGHT_INTENSITIES || { '無': '', '強': 'high intensity', '中': 'medium intensity', '弱': 'low intensity' };
        window.LIGHT_DISTANCES = window.LIGHT_DISTANCES || { '無': '', '遠': 'distant light source', '中': 'mid-distance light', '近': 'close light source' };
        window.THEME_LIST = window.THEME_LIST || [];

        window.getDynamicThemeInstruction = window.getDynamicThemeInstruction || ((theme) => {
            return { text: '', charName: null };
        });

        window.getStyleInstruction = window.getStyleInstruction || ((style, realismValue = 100, subStyle = 'chibi', pixelResolution = 256, gender = 'female', imageType = 'unknown', customPrompt = '', context = {}) => {
            const isChibi = style === 'chibi';
            let faceTreatment = style === 'realistic' ? 'Maintain realistic human features.' : 
                                style === 'anime' ? 'MUST use anime stylized facial features.' : 
                                'MUST use cute chibi stylized facial features.';
            return `**Art Style:** Stylized ${style} rendering.\n**Proportions:** ${isChibi?'Chibi (large head, small body)':'Appropriate for the requested style'}.\n**Face Treatment:** ${faceTreatment}\n**Likeness:** Preserve recognizable identity.`;
        });

        window.apiKey = "";
        window.generateTextWithRetry = async (payload, maxRetries = 3) => {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${window.apiKey}`;
            for (let i = 0; i < maxRetries; i++) {
                try { const res = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) }); if (!res.ok) throw new Error(`API: ${res.status}`); const data = await res.json(); const text = data?.candidates?.[0]?.content?.parts?.[0]?.text; if (text) return text; throw new Error("無回應"); } 
                catch (e) { if (i === maxRetries - 1) throw e; await new Promise(r => setTimeout(r, 1000 * Math.pow(2, i))); }
            }
        };
        window.generateImageWithRetry = async (payload, maxRetries = 3) => {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-image-preview:generateContent?key=${window.apiKey}`;
            for (let i = 0; i < maxRetries; i++) {
                try { const res = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) }); if (!res.ok) throw new Error(`API: ${res.status}`); const data = await res.json(); const inlineData = data.candidates?.[0]?.content?.parts?.find(p => p.inlineData)?.inlineData; if (!inlineData?.data) throw new Error("無圖片"); return `data:${inlineData.mimeType || 'image/jpeg'};base64,${inlineData.data}`; } 
                catch (e) { if (i === maxRetries - 1) throw e; await new Promise(r => setTimeout(r, 2000 * Math.pow(2, i))); }
            }
        };
        window.toBase64 = file => new Promise((resolve, reject) => { const reader = new FileReader(); reader.readAsDataURL(file); reader.onload = () => resolve(reader.result); reader.onerror = error => reject(error); });
        window.processDataUrl = (dataUrl) => { if (!dataUrl) return { mimeType: null, data: null }; const parts = dataUrl.split(','); if (parts.length !== 2) return { mimeType: null, data: null }; const mimeType = parts[0].match(/:(.*?);/)?.[1]; if (!mimeType) return { mimeType: null, data: null }; return { mimeType, data: parts[1] }; };
        window.WORD_FREQ_KEY = 'promptWordFrequencies';
        window.getWordFrequencies = () => { try { const stored = localStorage.getItem(window.WORD_FREQ_KEY); return stored ? JSON.parse(stored) : { positive: {}, negative: {} }; } catch (e) { return { positive: {}, negative: {} }; } };
        window.updateWordFrequencies = (text, type) => { if (!text || typeof text !== 'string') return; const freqs = window.getWordFrequencies(); text.toLowerCase().split(/[\s,，]+/).filter(w => w.length >= 3).forEach(w => { const cw = w.trim(); if (cw) freqs[type][cw] = (freqs[type][cw] || 0) + 1; }); try { localStorage.setItem(window.WORD_FREQ_KEY, JSON.stringify(freqs)); } catch (e) {} };
        window.getSuggestions = (type) => Object.entries(window.getWordFrequencies()[type] || {}).sort((a, b) => b[1] - a[1]).slice(0, 10).map(x => x[0]);
        
        window.drawGridForDetection = async (imageDataUrl) => {
            return new Promise((resolve) => {
                const img = new Image();
                img.crossOrigin = "Anonymous";
                img.onload = () => {
                    const c = document.createElement('canvas');
                    c.width = 1000; c.height = 1000;
                    const ctx = c.getContext('2d');
                    ctx.drawImage(img, 0, 0, 1000, 1000);
                    
                    ctx.strokeStyle = 'rgba(255, 0, 0, 0.8)';
                    ctx.fillStyle = 'rgba(255, 0, 0, 1)';
                    ctx.font = 'bold 20px Arial';
                    ctx.lineWidth = 1;
                    
                    for (let i = 0; i <= 100; i += 5) {
                        const pos = i * 10;
                        ctx.beginPath(); ctx.moveTo(pos, 0); ctx.lineTo(pos, 1000); ctx.stroke();
                        ctx.beginPath(); ctx.moveTo(0, pos); ctx.lineTo(1000, pos); ctx.stroke();
                        if (i % 10 === 0) {
                            ctx.fillText(i.toString(), pos + 5, 25);
                            ctx.fillText(i.toString(), 5, pos + 25);
                        }
                    }
                    resolve(c.toDataURL('image/jpeg', 0.8));
                };
                img.src = imageDataUrl;
            });
        };

        window.detectFaceGuidesAI = async (imageDataUrl) => {
            try {
                const gridImage = await window.drawGridForDetection(imageDataUrl);
                const { mimeType, data } = window.processDataUrl(gridImage);
                if (!mimeType || !data) return {};
                const res = await window.generateTextWithRetry({
                    contents: [{
                        parts: [
                            { text: "This portrait has a 0-100 coordinate grid overlaid (red lines). X: 0 left, 50 center, 100 right. Y: 0 top, 100 bottom. Read the grid carefully to estimate the exact coordinates of the subject's facial features. CRITICAL: For widths (Dx), measure from the center (50) to the ACTUAL SKIN EDGE of the face. DO NOT INCLUDE HAIR VOLUME. Exclude any hair framing the face." },
                            { inlineData: { mimeType, data } }
                        ]
                    }],
                    generationConfig: {
                        responseMimeType: "application/json",
                        responseSchema: {
                            type: "OBJECT",
                            properties: { 
                                headTopY: { type: "NUMBER", description: "Top of the physical head/hair" }, 
                                hairlineY: { type: "NUMBER", description: "Skin hairline on forehead" }, 
                                eyebrowY: { type: "NUMBER", description: "Y coordinate of eyebrows" }, 
                                eyeY: { type: "NUMBER", description: "Y coordinate of pupils" }, 
                                eyeCenterDx: { type: "NUMBER", description: "Distance from center 50 to the pupil. Usually 10-14" }, 
                                noseY: { type: "NUMBER", description: "Bottom of the nose" }, 
                                mouthY: { type: "NUMBER", description: "Center line of the lips" }, 
                                jawLowerY: { type: "NUMBER", description: "Jaw angle Y coordinate" }, 
                                chinY: { type: "NUMBER", description: "Very bottom of the chin" }, 
                                cheekboneDx: { type: "NUMBER", description: "Distance from center to actual skin edge at cheekbones. DO NOT include hair! Usually 15-23" }, 
                                jawUpperDx: { type: "NUMBER", description: "Distance from center to actual skin edge at jaw near ears. DO NOT include hair! Usually 15-22" } 
                            },
                            required: ["headTopY", "hairlineY", "eyebrowY", "eyeY", "eyeCenterDx", "noseY", "mouthY", "jawLowerY", "chinY", "cheekboneDx", "jawUpperDx"]
                        }
                    }
                });
                const p = JSON.parse(res);
                return {
                    headTopY: Math.min(Math.max(p.headTopY, 2), 25), 
                    hairlineY: Math.min(Math.max(p.hairlineY, 15), 35), 
                    eyebrowY: Math.min(Math.max(p.eyebrowY, 35), 55), 
                    eyeY: Math.min(Math.max(p.eyeY, 40), 60), 
                    eyeCenterDx: Math.min(Math.max(p.eyeCenterDx, 8), 16), 
                    noseY: Math.min(Math.max(p.noseY, 50), 70), 
                    mouthY: Math.min(Math.max(p.mouthY, 60), 80), 
                    jawLowerY: Math.min(Math.max(p.jawLowerY, 65), 85), 
                    chinY: Math.min(Math.max(p.chinY, 75), 95), 
                    chinBottomY: Math.min(Math.max(p.chinY, 75), 95) + 1, 
                    cheekboneDx: Math.min(Math.max(p.cheekboneDx, 15), 26), 
                    jawUpperDx: Math.min(Math.max(p.jawUpperDx, 14), 25)
                };
            } catch(e) { return {}; }
        };

        // 強化：利用 AI 自動分析照片並動態擴充造型選項
        window.detectFacialFeaturesAI = async (imageDataUrl, currentOptionsMap) => {
            try {
                const { mimeType, data } = window.processDataUrl(imageDataUrl);
                if (!mimeType || !data) return null;

                const schemaProperties = {};
                // 優化 Prompt：強制要求繁體中文，且舉例說明常見的動漫特徵
                let promptText = "Analyze the character's appearance in the image and classify them according to the following categories. Choose the EXACT string from 'Available Options' if it matches perfectly. If NO option fits the visual evidence, create a HIGHLY CONCISE new label in Traditional Chinese (e.g., '雙馬尾', '八字瀏海', '圓瞳', '貓咪唇'). Max 5 characters. Return JSON.\n\n";

                for (const [key, config] of Object.entries(currentOptionsMap)) {
                    // 排除一些不需要 AI 判斷的主觀設定
                    if (['artStyle', 'irisDetail', 'faceShape', 'skinTone'].includes(key)) continue; 
                    promptText += `- ${key} (${config.label}): Available Options: [${config.opts.join(', ')}]\n`;
                    schemaProperties[key] = { type: "STRING" };
                }

                const res = await window.generateTextWithRetry({
                    contents: [{
                        parts: [
                            { text: promptText },
                            { inlineData: { mimeType, data } }
                        ]
                    }],
                    generationConfig: {
                        responseMimeType: "application/json",
                        responseSchema: {
                            type: "OBJECT",
                            properties: schemaProperties
                        }
                    }
                });
                return JSON.parse(res);
            } catch(e) {
                console.error("Feature detection failed:", e);
                return null;
            }
        };

        window.detectImageProperties = async (imageDataUrl) => {
            try {
                const { mimeType, data } = window.processDataUrl(imageDataUrl); if (!mimeType || !data) throw new Error("Invalid Format");
                const res = await window.generateTextWithRetry({ contents: [{ parts: [{ text: "Analyze image. Determine 'photograph' or 'illustration', '2D' or '3D', 'personCount', 'gender' (male/female/all-male/all-female/mixed/unknown), 'isChibi' (true/false)." }, { inlineData: { mimeType, data } }] }], generationConfig: { responseMimeType: "application/json", responseSchema: { type: "OBJECT", properties: { type: { type: "STRING" }, dimension: { type: "STRING" }, gender: { type: "STRING" }, personCount: { type: "INTEGER" }, isChibi: { type: "BOOLEAN" } }, required: ["type", "dimension", "gender", "personCount", "isChibi"] } } });
                const props = JSON.parse(res); let g = 'unknown'; if (['male','all-male'].includes(props.gender?.toLowerCase())) g = 'male'; else if (['female','all-female'].includes(props.gender?.toLowerCase())) g = 'female'; else if (props.gender?.toLowerCase() === 'mixed') g = 'multiple'; if ((props.personCount || 0) <= 1 && g === 'multiple') g = 'unknown';
                return { type: props.type?.toLowerCase().includes('photo') ? 'photograph' : 'illustration', dimension: props.dimension?.toUpperCase() === '3D' ? '3D' : '2D', personCount: props.personCount || 0, gender: g, isChibi: !!props.isChibi };
            } catch (e) { return { type: 'unknown', gender: 'unknown', personCount: 0, dimension: 'unknown', isChibi: false }; }
        };
        window.generativeFill = async (imageDataUrl) => { const { mimeType, data } = window.processDataUrl(imageDataUrl); return await window.generateImageWithRetry({ contents: [{ parts: [{ text: "Outpainting: REDRAW entire image to fill frame. Maintain subject identity, pose, clothing. Invent fitting background. Keep style consistent." }, { inlineData: { mimeType, data } }] }], generationConfig: { responseModalities: ['TEXT', 'IMAGE'] } }); };
        window.createSilhouetteMaskAI = async (imageDataUrl) => { const { mimeType, data } = window.processDataUrl(imageDataUrl); return await window.generateImageWithRetry({ contents: [{ parts: [{ text: "Create black and white silhouette mask. Subject black, background white." }, { inlineData: { mimeType, data } }] }], generationConfig: { responseModalities: ['TEXT', 'IMAGE'] } }); };
        window.replaceBackgroundWithColorAI = async (imageDataUrl, colorName = 'green') => { const colors = { green: '#00FF00', red: '#FF0000', blue: '#0000FF', black: '#000000', white: '#FFFFFF' }; const { mimeType, data } = window.processDataUrl(imageDataUrl); return await window.generateImageWithRetry({ contents: [{ parts: [{ text: `Change the ENTIRE background to flat, solid, unshaded ${colorName} (${colors[colorName]}). The background MUST be a perfectly uniform color with NO shadows, NO gradients, and NO textures. PRESERVE THE SUBJECT PERFECTLY.` }, { inlineData: { mimeType, data } }] }], generationConfig: { responseModalities: ['TEXT', 'IMAGE'] } }); };
        
        window.resizeImage = (url, w, h) => new Promise((res, rej) => { const img = new Image(); img.crossOrigin = 'Anonymous'; img.onload = () => { const c = document.createElement('canvas'); c.width = w; c.height = h; const ctx = c.getContext('2d'); ctx.imageSmoothingEnabled = true; ctx.imageSmoothingQuality = 'high'; ctx.drawImage(img, 0, 0, w, h); res(c.toDataURL('image/png')); }; img.onerror = rej; img.src = url; });
