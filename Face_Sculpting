                                                                <div className="space-y-6 pt-4 border-t border-gray-700 mt-4">
                                                                    <div className="flex flex-wrap gap-3">
                                                                        <button onClick={()=>setOptions(o=>({...o,generateBackground:!o.generateBackground}))} className={`px-4 py-1.5 rounded-lg text-sm font-semibold ${options.generateBackground?'bg-indigo-600 text-white':'bg-gray-700 text-gray-300'}`}>生成背景</button>
                                                                        <button onClick={()=>setOptions(o=>({...o,disableDefaultLighting:!o.disableDefaultLighting}))} className={`px-4 py-1.5 rounded-lg text-sm font-semibold ${options.disableDefaultLighting?'bg-indigo-600 text-white':'bg-gray-700 text-gray-300'}`}>關閉光源</button>
                                                                        <button onClick={()=>setOptions(o=>({...o,unifyStyle:!o.unifyStyle}))} className={`px-4 py-1.5 rounded-lg text-sm font-semibold ${options.unifyStyle?'bg-indigo-600 text-white':'bg-gray-700 text-gray-300'}`}>風格統一</button>
                                                                        <button onClick={()=>setOptions(o=>({...o,lookAtCamera:!o.lookAtCamera}))} className={`px-4 py-1.5 rounded-lg text-sm font-semibold ${!options.lookAtCamera?'bg-indigo-600 text-white':'bg-gray-700 text-gray-300'}`}>無視鏡頭</button>
                                                                        <button onClick={()=>setIsCharCreatorMode(p=>!p)} className={`px-4 py-1.5 rounded-lg text-sm font-semibold ${isCharCreatorMode?'bg-indigo-600 text-white':'bg-gray-700 text-gray-300'}`}>捏臉系統</button>
                                                                    </div>
                                                                    <div className="flex flex-wrap gap-3 items-center">
                                                                        <button onClick={()=>setOptions(o=>({...o,removeBackground:!o.removeBackground}))} className={`px-4 py-1.5 rounded-lg text-sm font-semibold ${options.removeBackground?'bg-indigo-600 text-white':'bg-gray-700 text-gray-300'}`}>去背</button>
                                                                        <div className="flex gap-1.5 items-center bg-gray-800 p-1.5 rounded-lg">
                                                                            <span className="text-xs text-gray-400 mr-1">色鍵:</span>
                                                                            {['green','red','blue','black','white'].map(col=>{
                                                                                const bgCls = col === 'green' ? 'bg-green-500' : col === 'red' ? 'bg-red-500' : col === 'blue' ? 'bg-blue-500' : col === 'black' ? 'bg-black' : 'bg-white';
                                                                                return <button key={col} onClick={()=>setOptions(o=>({...o,chromaKeyColor:col}))} className={`w-5 h-5 rounded ${bgCls} border-2 transition-colors ${options.chromaKeyColor===col?(col==='white'?'border-gray-400':'border-white'):'border-transparent'}`}></button>
                                                                            })}
                                                                        </div>
                                                                        <button onClick={()=>setOptions(o=>({...o,addWhiteBorder:!o.addWhiteBorder}))} disabled={!options.removeBackground} className={`px-4 py-1.5 rounded-lg text-sm font-semibold disabled:opacity-50 ${options.addWhiteBorder?'bg-indigo-600 text-white':'bg-gray-700 text-gray-300'}`}>白邊</button>
                                                                        <button onClick={()=>setOptions(o=>({...o,applyBottomCrop:!o.applyBottomCrop}))} disabled={!options.removeBackground} className={`px-4 py-1.5 rounded-lg text-sm font-semibold disabled:opacity-50 ${options.applyBottomCrop?'bg-indigo-600 text-white':'bg-gray-700 text-gray-300'}`}>收邊</button>
                                                                    </div>
                                                                    <div className="flex flex-wrap gap-3"><button onClick={async ()=>{const m='none';const oM=options.textMode;setOptions(o=>({...o,textMode:m}));if(m===oM||m==='english'||isLoading||isSingleRegenActive||!generatedImages.length)return;setIsAppTxt(true);try{setGeneratedImages(generatedImages.map(i=>(i.status==='success'&&i.baseImageUrl&&!i.customText)?{...i,imageUrl:i.baseImageUrl}:i));}catch(e){}finally{setIsAppTxt(false);}}} className={`px-4 py-1.5 rounded-lg text-sm font-semibold ${options.textMode==='none'?'bg-indigo-600 text-white':'bg-gray-700 text-gray-300'}`}>生圖</button><button onClick={()=>setOptions(o=>({...o,textMode:'english'}))} className={`px-4 py-1.5 rounded-lg text-sm font-semibold ${options.textMode==='english'?'bg-indigo-600 text-white':'bg-gray-700 text-gray-300'}`}>英文</button><button onClick={async ()=>{const m='chinese';const oM=options.textMode;setOptions(o=>({...o,textMode:m}));if(m===oM||m==='english'||isLoading||isSingleRegenActive||!generatedImages.length)return;setIsAppTxt(true);try{setGeneratedImages(await Promise.all(generatedImages.map(async i=>{if(i.status==='success'&&i.baseImageUrl&&!i.customText){const ids=i.id.split('+'),pId=ids[ids.length-1],p=window.GENERATION_PROMPTS.find(x=>x.id===pId)||window.GENERATION_PROMPTS.find(x=>x.id===ids[0]);if(p&&p.memeTextZH)try{return{...i,imageUrl:await window.addTextToImage(i.baseImageUrl,[p.memeTextZH])};}catch(e){return i;}}return i;})));}catch(e){}finally{setIsAppTxt(false);}}} className={`px-4 py-1.5 rounded-lg text-sm font-semibold ${options.textMode==='chinese'?'bg-indigo-600 text-white':'bg-gray-700 text-gray-300'}`}>中文</button></div>
                                                                </div>
                                                            </motion.div>
                                                        )}
                                                    </AnimatePresence>
                                                </div>
                                            </fieldset>
                                        </div>
                                    </div>
                                </div>

                                <div className="my-12 flex flex-col sm:flex-row items-center justify-center gap-6">
                                    {isLoading ? (
                                        <div className="flex w-full max-w-sm h-16 rounded-full overflow-hidden border-2 border-gray-700/50 shadow-lg bg-gray-800 mx-auto">
                                            <div className="w-1/2 h-full"><button onClick={()=>setIsPaused(!isPaused)} className={`w-full h-full text-lg font-bold flex items-center justify-center ${isPaused?'bg-brushed-midnight-blue text-white animate-halo-midnight-blue':'bg-brushed-gray text-white animate-halo-gray'}`}><IconSparkles /><span>{isPaused?'繼續':'暫停'}</span></button></div>
                                            <div className="w-1/2 h-full"><button onClick={cancelGeneration} className="w-full h-full text-white text-lg font-bold flex items-center justify-center bg-brushed-red animate-halo-red"><IconStop /><span>取消</span></button></div>
                                        </div>
                                    ) : (
                                        <button onClick={hdGen} disabled={!uploadedImage||isUploading||isSingleRegenActive||(selStickers.length===0&&lockedStickers.length===0)} className={`w-auto px-32 h-16 rounded-full text-white text-xl font-bold flex items-center justify-center border-2 bg-brushed-cyan border-[#4a8999] focus:ring-4 focus:ring-[#62B6CB] ${(!uploadedImage||isUploading||isSingleRegenActive||(selStickers.length===0&&lockedStickers.length===0))?'opacity-50 cursor-not-allowed':'animate-halo-cyan'}`}><IconSparkles /><span>{isPaused?'繼續生成':'生成貼圖'}</span></button>
                                    )}
                                </div>

                                <div ref={resRef}>
                                    {generatedImages.length > 0 && (
                                        <div className="mt-8">
                                            <h2 className="text-3xl font-bold text-white mb-8 text-center">您的貼圖</h2>
                                            {isLoading && <div className="w-full max-w-4xl mx-auto mb-8 text-center"><div className="bg-gray-800 rounded-full h-3"><motion.div className="bg-[#62B6CB] h-3" initial={{width:0}} animate={{width:`${progress}%`}} /></div><p className="text-gray-400 mt-4 text-sm">生成中...</p></div>}
                                            <div className="grid gap-4 sm:gap-6 mt-8 grid-cols-2 sm:grid-cols-4">
                                                {(() => {
                                                    const els = []; const pIds = new Set();
                                                    generatedImages.forEach((img, i) => { if(pIds.has(img.id))return; els.push(img.status==='success'?<StickerDisplay key={`${img.id}-${i}`} index={i} img={img} onDownload={(u,n)=>{const a=document.createElement('a');a.href=u;a.download=`s-${n}.png`;a.click();}} onRegenerate={()=>regenerateImage(i)} onPreview={u=>{setPrevUrl(u);setIsPrevOpen(true);}} onSetReference={()=>setOptions(o=>({...o,styleReferenceImage:o.styleReferenceImage===img.imageUrl?null:img.imageUrl}))} isReference={options.styleReferenceImage===img.imageUrl} onDirectionalRegenerate={d=>{const r={...generatedImages[i].rotation};if(d==='up'&&r.v<2)r.v++;else if(d==='down'&&r.v>-2)r.v--;else if(d==='left'&&r.h>-2)r.h--;else if(d==='right'&&r.h<2)r.h++;regenerateImage(i,{rotation:r});}} isDisabled={isLock} onEditText={idx=>setEditTxt({index:idx,text:idx!==null?generatedImages[idx]?.customText||'':''})} isEditingText={editTxt.index===i} customText={editTxt.index===i?editTxt.text:img.customText} onCustomTextChange={e=>setEditTxt(p=>({...p,text:e.target.value}))} onSaveText={async ()=>{const{index:idx,text:t}=editTxt;if(idx===null)return;setIsAppTxt(true);const m=generatedImages[idx],b=m.baseImageUrl||m.imageUrl,n=t?await window.addTextToImage(b,[t]):b;setGeneratedImages(x=>x.map((y,j)=>j===idx?{...y,imageUrl:n,customText:t}:y));setEditTxt({index:null,text:''});setIsAppTxt(false);}}/>:<ResultCard key={`${img.id}-${i}`} status={img.status} emotion={img.id} onRegenerate={()=>regenerateImage(i)}/>); pIds.add(img.id); });
                                                    return els;
                                                })()}
                                            </div>
                                            {!isLoading && generatedImages.some(i=>i.status==='success') && (
                                                <div className="mt-12 flex justify-center"><Button onClick={async ()=>{if(isZip)return;setIsZip(true);try{const z=new window.JSZip(),s=generatedImages.filter(i=>i.status==='success');if(!s.length)return;await Promise.all(s.map(async i=>z.file(`${options.style}-${i.id}.png`,await(await fetch(i.imageUrl)).blob())));const b=await z.generateAsync({type:"blob"}),a=document.createElement("a");a.href=URL.createObjectURL(b);a.download="stickers.zip";a.click();URL.revokeObjectURL(a.href);}catch(e){}finally{setIsZip(false);}}} primary disabled={isZip} className="h-16 px-8 text-xl"><div className="flex items-center gap-2">{isZip?<><div className="animate-spin rounded-full h-5 w-5 border-t-2 border-b-2 border-white"></div><span>打包中...</span></>:<><IconZip /><span>打包下載</span></>}</div></Button></div>
                                            )}
                                        </div>
                                    )}
                                </div>
                            </main>
                        </div>
                    </div>
                </React.Fragment>
            );
        };

        const rootE = document.getElementById('root');
        if (rootE) ReactDOM.createRoot(rootE).render(<App />);
    </script>
</body>
</html>
