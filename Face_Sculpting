    <script>window.__IS_OFFLINE__ = true;</script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@800&family=Noto+Sans+TC:wght@700&family=Zhi+Mang+Xing&display=swap'); 
        body { font-family: 'Inter', sans-serif; background-color: #000; -webkit-user-select: none; user-select: none; -webkit-touch-callout: none; } 
        input[type=number]::-webkit-inner-spin-button, input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; } 
        input[type=number] { -moz-appearance: textfield; } 
        input[type=range] { -webkit-appearance: none; background: transparent; }
        input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; height: 16px; width: 16px; border-radius: 50%; background: #22c55e; cursor: pointer; margin-top: -6px; }
        input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 4px; cursor: pointer; background: #374151; border-radius: 2px; }
        .bg-checkerboard-pattern { background-color: #404040; background-image: linear-gradient(45deg, #666 25%, transparent 25%), linear-gradient(135deg, #666 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #666 75%), linear-gradient(135deg, transparent 75%, #666 75%); background-size: 20px 20px; background-position: 0 0, 10px 0, 10px -10px, 0px 10px; } 
        @keyframes fade-in-down { from { opacity: 0; transform: translateY(-20px) translateX(-50%); } to { opacity: 1; transform: translateY(0) translateX(-50%); } } 
        .animate-fade-in-down { animation: fade-in-down 0.5s ease-out forwards; }
        .bg-brushed-cyan { background-color: #62B6CB; background-image: linear-gradient(175deg, rgba(255,255,255,0.4) 0%, rgba(150, 200, 220, 0.2) 15%, rgba(0,0,0,0.1) 40%, rgba(255,255,255,0.3) 70%, rgba(80, 150, 180, 0.2) 90%, rgba(255,255,255,0.5) 100%); } 
        .bg-brushed-red { background-color: #8B0000; background-image: linear-gradient(175deg, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0.05) 15%, rgba(0,0,0,0.1) 40%, rgba(255,255,255,0.1) 70%, rgba(50,0,0,0.2) 90%, rgba(255,255,255,0.25) 100%); } 
        .bg-brushed-gray { background-color: #4c4c4c; background-image: linear-gradient(175deg, rgba(255,255,255,0.15) 0%, rgba(200,200,200,0.05) 15%, rgba(20,20,20,0.1) 40%, rgba(255,255,255,0.1) 70%, rgba(80,80,80,0.2) 90%, rgba(255,255,255,0.2) 100%); } 
        .bg-brushed-midnight-blue { background-color: #191970; background-image: linear-gradient(175deg, rgba(173,216,230,0.3) 0%, rgba(100,149,237,0.15) 15%, rgba(0,0,0,0.1) 40%, rgba(135,206,250,0.2) 70%, rgba(25,25,112,0.2) 90%, rgba(240,248,255,0.3) 100%); } 
        @keyframes halo-pulse-cyan { 0% { box-shadow: 0 0 0 0 rgba(98, 182, 203, 0.5); } 100% { box-shadow: 0 0 0 25px rgba(98, 182, 203, 0); } } 
        .animate-halo-cyan { animation: halo-pulse-cyan 2.5s infinite cubic-bezier(0.215, 0.61, 0.355, 1); } 
        @keyframes halo-pulse-red { 0% { box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.6); } 100% { box-shadow: 0 0 0 20px rgba(220, 38, 38, 0); } } 
        .animate-halo-red { animation: halo-pulse-red 2.5s infinite cubic-bezier(0.215, 0.61, 0.355, 1); } 
        @keyframes halo-pulse-midnight-blue { 0% { box-shadow: 0 0 0 0 rgba(79, 70, 229, 0.6); } 100% { box-shadow: 0 0 0 20px rgba(79, 70, 229, 0); } } 
        .animate-halo-midnight-blue { animation: halo-pulse-midnight-blue 2.5s infinite cubic-bezier(0.215, 0.61, 0.355, 1); } 
        @keyframes halo-pulse-gray { 0% { box-shadow: 0 0 0 0 rgba(156, 163, 175, 0.5); } 100% { box-shadow: 0 0 0 20px rgba(156, 163, 175, 0); } } 
        .animate-halo-gray { animation: halo-pulse-gray 2.5s infinite cubic-bezier(0.215, 0.61, 0.355, 1); }
